 var seed = Math.floor(Date.now() / (10 * 60 * 1000));\
\
 // Simple seeded shuffle so the same 10-min block always shows the same 8\
 function seededRand(s) \{\
 var x = Math.sin(s + 1) * 10000;\
 return x - Math.floor(x);\
 \}\
\
 var pool = CC_POOL.slice();\
 // Shuffle using seed\
 for (var i = pool.length - 1; i > 0; i--) \{\
 var j = Math.floor(seededRand(seed + i) * (i + 1));\
