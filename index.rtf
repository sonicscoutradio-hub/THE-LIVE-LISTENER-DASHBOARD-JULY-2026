 letter-spacing:.35em; color:var(--amber);\
 text-transform:uppercase; margin-bottom:2px;\
\}\
.brand-text h1 \{\
 font-family:'Syne',sans-serif; font-size:28px; font-weight:800;\
 letter-spacing:-.01em; line-height:1;\
