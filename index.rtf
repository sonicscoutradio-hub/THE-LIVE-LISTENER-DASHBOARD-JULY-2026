// PRESENTER LOGIN & CHAT \
var APPS_SCRIPT_URL = 'https://script.google.com/macros/s/AKfycbxWQ7I8yvtoMeJtNoHidZvMwhZu16hSawU4CXhaakxhnI_W7Q1fMeVXmkVZOEB87sCR/exec';\
var _presenterSession = null; // \{ name, pwd, show \} when logged in\
var _seenChatIds = \{\}; // tracks which chat messages we've already shown\
var _lastListenerMessages = []; // recent listener messages (for reply context)\
\
// Open login modal\
function openPresenterLogin() \{\
 document.getElementById('presenterLoginModal').style.display = 'flex';\
 document.getElementById('presenterLoginErr').textContent = '';\
 setTimeout(function()\{\
 var pwd = document.getElementById('presenterPwd');\
 if (pwd) pwd.focus();\
 \}, 100);\
\}\
\
function closePresenterLogin() \{\
 document.getElementById('presenterLoginModal').style.display = 'none';\
 document.getElementById('presenterPwd').value = '';\
 document.getElementById('presenterNameSel').value = '';\
 document.getElementById('presenterLoginErr').textContent = '';\
\}\
\
function submitPresenterLogin() \{\
 var name = document.getElementById('presenterNameSel').value;\
 var pwd = document.getElementById('presenterPwd').value;\
 var err = document.getElementById('presenterLoginErr');\
\
 if (!name) \{ err.textContent = 'Please select your name'; return; \}\
 if (!pwd) \{ err.textContent = 'Enter password'; return; \}\
\
 // Store session locally and try a test post to verify password\
 err.textContent = 'Verifying...';\
\
 // Quick test: attempt a "verify" post (we'll just check if chat GET works after)\
 // Actually: no verification endpoint, so we'll just store and trust\
 // Wrong passwords will fail at first real reply\
 _presenterSession = \{ name: name, pwd: pwd \};\
 try \{\
 sessionStorage.setItem('ssrPresenter', JSON.stringify(_presenterSession));\
 \} catch(e) \{\}\
\
 closePresenterLogin();\
 enterPresenterMode();\
\}\
\
function enterPresenterMode() \{\
 if (!_presenterSession) return;\
 document.body.classList.add('presenter-mode');\
 // Update presenter review button label\
 var lbl = document.getElementById('prTriggerLabel');\
 if (lbl) lbl.textContent = 'Presenter Review';\
 // If login was triggered from the review button, auto-open the box\
 if (_presenterReviewPendingOpen) \{\
 _presenterReviewPendingOpen = false;\
 setTimeout(presenterReviewToggle, 200);\
 \}\
\}\
\
function presenterLogout() \{\
 _presenterSession = null;\
 try \{ sessionStorage.removeItem('ssrPresenter'); \} catch(e) \{\}\
 document.body.classList.remove('presenter-mode');\
\}\
\
// Restore session on page load\
(function() \{\
 try \{\
 var saved = sessionStorage.getItem('ssrPresenter');\
 if (saved) \{\
 _presenterSession = JSON.parse(saved);\
 // Enter mode once DOM is ready\
 setTimeout(enterPresenterMode, 200);\
 \}\
 \} catch(e) \{\}\
\})();\
