 var weights = [1.0, 0.78, 0.62, 0.50, 0.40, 0.32, 0.25, 0.18];\
 weights = weights.map(function(w) \{ return w + (Math.random() * 0.10 - 0.05); \});\
 var sum = weights.reduce(function(a, b) \{ return a + b; \}, 0);\
