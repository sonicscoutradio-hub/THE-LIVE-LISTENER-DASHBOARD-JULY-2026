 return '' +\
 '<div class="show-card' + (isLive ? ' live' : '') + (isComingSoon ? ' coming-soon' : '') + '">' +\
 '<div class="show-top">' +\
 '<div class="show-art">' + artHtml + '</div>' +\
 '<div class="show-meta">' +\
 '<div class="show-name">' + show.name + '</div>' +\
 '<div class="show-host">' + show.host + '</div>' +\
