// \
// WEEKLY DATE RANGE + AUTO-REFRESH (EST) \
// \
// Computes the current broadcast week (MonSun in US Eastern time),\
// updates both date displays on the dashboard, and schedules an\
// automatic page refresh at 11:59 PM EST every Sunday so the new\
// week's range appears at the start of Monday's broadcast cycle.\
\
(function setupWeeklyDates() \{\
 var MONTHS_LONG = ['January','February','March','April','May','June',\
 'July','August','September','October','November','December'];\
 var MONTHS_SHORT = ['JAN','FEB','MAR','APR','MAY','JUN',\
 'JUL','AUG','SEP','OCT','NOV','DEC'];\
\
 // Get the current date as it would appear in US Eastern time\
 // (handles EST/EDT automatically via Intl).\
 function getEasternNow() \{\
 var parts = new Intl.DateTimeFormat('en-US', \{\
 timeZone: 'America/New_York',\
 year: 'numeric', month: '2-digit', day: '2-digit',\
 hour: '2-digit', minute: '2-digit', second: '2-digit',\
 hour12: false\
 \}).formatToParts(new Date());\
 var p = \{\};\
 parts.forEach(function(x) \{ p[x.type] = x.value; \});\
 return \{\
 year: parseInt(p.year, 10),\
 month: parseInt(p.month, 10), // 1-12\
 day: parseInt(p.day, 10),\
 hour: parseInt(p.hour === '24' ? '0' : p.hour, 10),\
 minute: parseInt(p.minute, 10),\
 second: parseInt(p.second, 10)\
 \};\
 \}\
\
 // Given the Eastern "now", figure out the Monday of the current week.\
 // Week defined as Monday 00:00 EST through Sunday 23:59 EST.\
 function getWeekRange() \{\
 var now = getEasternNow();\
 // Build a date at noon Eastern (noon avoids any DST-edge weirdness).\
 var d = new Date(Date.UTC(now.year, now.month - 1, now.day, 12, 0, 0));\
 // getUTCDay: 0=Sun, 1=Mon, ..., 6=Sat. We want Monday as start.\
 var dow = d.getUTCDay();\
 var daysSinceMonday = (dow === 0) ? 6 : (dow - 1); // Sunday counts as last day of prior week\
 var monday = new Date(d.getTime() - daysSinceMonday * 86400000);\
 var sunday = new Date(monday.getTime() + 6 * 86400000);\
 return \{ start: monday, end: sunday \};\
 \}\
\
 function formatLong(d) \{\
 return d.getUTCDate() + ' ' + MONTHS_LONG[d.getUTCMonth()];\
 \}\
 function formatShort(d) \{\
 return d.getUTCDate() + ' ' + MONTHS_SHORT[d.getUTCMonth()];\
 \}\
\
 function updateWeekDisplays() \{\
 try \{\
 var range = getWeekRange();\
 var startLong = formatLong(range.start);\
 var endLong = formatLong(range.end);\
 var year = range.end.getUTCFullYear();\
 var startShort = formatShort(range.start);\
 var endShort = formatShort(range.end);\
 var yearShort = String(year).slice(-2);\
\
 var shortEl = document.getElementById('weekRangeShort');\
 var longEl = document.getElementById('weekRangeLong');\
 if (shortEl) \{\
 shortEl.textContent = startShort + '  ' + endShort + ' ' + yearShort;\
 \}\
 if (longEl) \{\
 longEl.textContent = startLong + '  ' + endLong + ' ' + year + ' // Avg listeners per broadcast';\
 \}\
 console.log('[SSR week] Week range set to', startLong, '', endLong, year);\
 \} catch (e) \{\
 console.warn('[SSR week] Failed to update week display:', e);\
 \}\
 \}\
\
 // Re-check every hour in case the user leaves the page open across days\
 setInterval(updateWeekDisplays, 60 * 60 * 1000);\
\
 // Compute milliseconds until next Sunday 23:59 (11:59 PM) Eastern time.\
 function msUntilNextSundayMidnightEastern() \{\
 var now = getEasternNow();\
 var refUTC = new Date(Date.UTC(now.year, now.month - 1, now.day, 12, 0, 0));\
 var dow = refUTC.getUTCDay();\
 var daysUntilSunday = (dow === 0) ? 0 : (7 - dow);\
 var nowUtc = new Date();\
 var nowEasternMs = Date.UTC(now.year, now.month - 1, now.day, now.hour, now.minute, now.second);\
 var utcOffsetMs = nowUtc.getTime() - nowEasternMs;\
 var targetEasternMs = Date.UTC(now.year, now.month - 1, now.day + daysUntilSunday, 23, 59, 0);\
 var targetUtcMs = targetEasternMs + utcOffsetMs;\
 var deltaMs = targetUtcMs - nowUtc.getTime();\
 if (deltaMs <= 0) deltaMs += 7 * 86400000;\
 return deltaMs;\
 \}\
\
 function scheduleWeeklyRefresh() \{\
 var delay = msUntilNextSundayMidnightEastern();\
 var hours = Math.round(delay / 3600000 * 10) / 10;\
 console.log('[SSR refresh] Auto-refresh scheduled in', hours, 'hours (next Sunday 11:59 PM EST)');\
 setTimeout(function() \{\
 console.log('[SSR refresh] Triggering weekly auto-refresh now');\
 updateWeekDisplays();\
 setTimeout(function() \{ window.location.reload(); \}, 2000);\
 \}, delay);\
 \}\
\
 // Run once on load, then schedule Sunday night auto-reload\
 updateWeekDisplays();\
 scheduleWeeklyRefresh();\
\
\})();\
