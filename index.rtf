 window._highestPeakHour = formatTime(hour).replace(':00','');\
 var dayNames=['Sun','Mon','Tue','Wed','Thu','Fri','Sat'];\
 var estDateForPeak = new Date(new Date().toLocaleString('en-US',\{timeZone:'America/New_York'\}));\
