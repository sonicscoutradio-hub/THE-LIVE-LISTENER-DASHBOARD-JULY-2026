 // Fallback to existing weekday-based labels\
 if (daysSinceMonday === 0 && estDate.getHours() < 8) peakLabel = 'Mon ' + estDate.getHours() + (estDate.getHours() < 12 ? 'am' : 'pm');\
 else if (daysSinceMonday === 0) peakLabel = 'Mon 7am  Hello World';\
 else if (daysSinceMonday === 1) peakLabel = 'Tue 7am  Hello World';\
 else if (daysSinceMonday === 2) peakLabel = 'Wed 7am  Hello World';\
 else if (daysSinceMonday === 3) peakLabel = 'Thu 7am  Hello World';\
