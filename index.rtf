\}\
.sched-new .sched-show \{ color:var(--amber-br); \}\
.sched-new-badge \{\
 display:inline-block;\
 background:var(--amber);\
 color:#000;\
 font-family:'JetBrains Mono',monospace;\
 font-size:8px;\
 font-weight:700;\
 letter-spacing:.15em;\
 padding:1px 6px;\
 border-radius:2px;\
\}\
\
/* TOP TRACKS PANEL */\
.tracks-list \{\
 display:flex;\
 flex-direction:column;\
 gap:8px;\
 margin-top:4px;\
\}\
\
/* RECENTLY PLAYED (sub-section inside Top 10 panel) */\
.recently-section \{\
 margin-top: 18px;\
 padding-top: 14px;\
 border-top: 1px dashed rgba(232,112,10,0.22);\
\}\
.recently-section-header \{\
 display: flex;\
 align-items: baseline;\
 justify-content: space-between;\
 margin-bottom: 10px;\
\}\
.recently-section-title \{\
 font-family: 'Syne', sans-serif;\
 font-weight: 700;\
 font-size: 14px;\
 color: var(--amber-br);\
 letter-spacing: -0.01em;\
\}\
.recently-section-meta \{\
 font-size: 9px;\
 letter-spacing: 0.25em;\
 color: var(--text);\
 text-transform: uppercase;\
\}\
