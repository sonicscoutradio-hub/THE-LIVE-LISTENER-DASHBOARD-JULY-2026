// POLL FOR NEW PRESENTER MESSAGES \
function pollPresenterMessages() \{\
 if (!APPS_SCRIPT_URL) return;\
\
 fetch(APPS_SCRIPT_URL + '?action=chat', \{\
 method: 'GET',\
 cache: 'no-store'\
 \})\
 .then(function(res) \{ return res.json(); \})\
 .then(function(data) \{\
 if (!data || !data.success || !data.messages) \{\
 console.log('[SSR chat poll] No messages or bad response');\
 return;\
 \}\
 var newCount = 0;\
 data.messages.forEach(function(msg) \{\
 if (!_seenChatIds[msg.id]) \{\
 _seenChatIds[msg.id] = true;\
 // Display any unseen message from the last 5 minutes\
 var ts = new Date(msg.timestamp).getTime();\
 var ageSeconds = (Date.now() - ts) / 1000;\
 console.log('[SSR chat poll] New message', msg.id, 'age', ageSeconds.toFixed(1) + 's', 'from', msg.presenter);\
 if (ageSeconds < 300) \{ // 5 minutes\
 showPresenterReply(msg);\
 newCount++;\
 \} else \{\
 console.log('[SSR chat poll] Skipping stale message (>5min old)');\
 \}\
 \}\
 \});\
 if (newCount > 0) console.log('[SSR chat poll] Displayed', newCount, 'new presenter replies');\
 \})\
 .catch(function(err) \{\
 console.log('[SSR chat poll] FAILED:', err && err.message ? err.message : err);\
 \});\
\}\
\
// Mark existing chat messages as seen on first load (avoid replaying old ones)\
function markExistingAsSeen() \{\
 fetch(APPS_SCRIPT_URL + '?action=chat')\
 .then(function(res) \{ return res.json(); \})\
 .then(function(data) \{\
 if (data && data.messages) \{\
 data.messages.forEach(function(m) \{ _seenChatIds[m.id] = true; \});\
 \}\
 \})\
 .catch(function()\{\});\
\}\
\
// Kick off polling\
setTimeout(markExistingAsSeen, 1000);\
setInterval(pollPresenterMessages, 7000); // Poll every 7 seconds\
\
// Attach reply buttons to existing items on page load\
setTimeout(attachReplyButtons, 1500);\
setInterval(attachReplyButtons, 3000); // Re-scan as new items get added\
