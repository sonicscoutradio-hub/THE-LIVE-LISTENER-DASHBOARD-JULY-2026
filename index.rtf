// RENDER SHOWS GRID\
function renderShowsGrid() \{\
 var current = getCurrentShow().show;\
 var grid = document.getElementById('showsGrid');\
 var dayNames = ['Mon','Tue','Wed','Thu','Fri','Sat','Sun'];\
\
 // Compute week progress for scaling the live-building stats\
 var now = new Date();\
 var estDate = new Date(now.toLocaleString('en-US', \{ timeZone: 'America/New_York' \}));\
