// REPLY MODAL \
var _currentReplyContext = '';\
\
function openReplyModal(listenerMessage) \{\
 if (!_presenterSession) \{\
 alert('Please login as presenter first');\
 return;\
 \}\
 _currentReplyContext = listenerMessage;\
 var ctx = document.getElementById('replyContext');\
 // Truncate long messages for display\
 var shown = listenerMessage.length > 80 ? listenerMessage.substring(0, 80) + '...' : listenerMessage;\
 ctx.textContent = 'Replying to: ' + shown;\
 document.getElementById('presenterReplyErr').textContent = '';\
 document.getElementById('presenterReplyText').value = '';\
 document.getElementById('presenterReplyModal').style.display = 'flex';\
 setTimeout(function()\{\
 document.getElementById('presenterReplyText').focus();\
 \}, 100);\
\}\
\
function closePresenterReply() \{\
 document.getElementById('presenterReplyModal').style.display = 'none';\
 document.getElementById('presenterReplyText').value = '';\
 _currentReplyContext = '';\
\}\
\
function submitPresenterReply() \{\
 if (!_presenterSession) return;\
 var text = document.getElementById('presenterReplyText').value.trim();\
 var err = document.getElementById('presenterReplyErr');\
\
 if (!text) \{ err.textContent = 'Please type a reply'; return; \}\
 if (!APPS_SCRIPT_URL || APPS_SCRIPT_URL.indexOf('YOUR_') === 0) \{\
 err.textContent = 'Apps Script URL not configured';\
 return;\
 \}\
\
 err.textContent = 'Sending...';\
\
 var currentShow = getCurrentShow().show;\
 var payload = \{\
 action: 'chat',\
 password: _presenterSession.pwd,\
 presenter: _presenterSession.name,\
 show: currentShow ? currentShow.name : '',\
 message: text,\
 replyTo: _currentReplyContext.substring(0, 100)\
 \};\
\
 console.log('[SSR chat POST] Sending presenter reply:', payload);\
\
 fetch(APPS_SCRIPT_URL, \{\
 method: 'POST',\
 mode: 'cors',\
 body: JSON.stringify(payload),\
 headers: \{ 'Content-Type': 'text/plain' \} // text/plain avoids CORS preflight on Apps Script\
 \})\
 .then(function(res) \{\
 console.log('[SSR chat POST] HTTP', res.status);\
 return res.json();\
 \})\
 .then(function(data) \{\
 console.log('[SSR chat POST] Response:', data);\
 if (data.success) \{\
 closePresenterReply();\
 // Optimistically show the reply in this user's feed too\
 if (data.message) \{\
 showPresenterReply(data.message);\
 _seenChatIds[data.message.id] = true;\
 \}\
 \} else \{\
 err.textContent = data.error || 'Failed to send';\
 if ((data.error || '').toLowerCase().indexOf('password') >= 0) \{\
 // Wrong password - force relogin\
 setTimeout(function() \{\
 presenterLogout();\
 err.textContent = 'Wrong password - please login again';\
 \}, 1500);\
 \}\
 \}\
 \})\
 .catch(function(err2) \{\
 err.textContent = 'Network error: ' + err2.message;\
 \});\
\}\
\
// SHOW PRESENTER REPLY IN FEED \
function showPresenterReply(msg) \{\
 var feed = document.getElementById('activityFeed');\
 if (!feed) return;\
\
 var div = document.createElement('div');\
 div.className = 'activity-item presenter-reply';\
\
 // Escape message\
 var tmp = document.createElement('div');\
 tmp.textContent = msg.message;\
 var safeMsg = tmp.innerHTML;\
\
 div.innerHTML =\
 '<span class="activity-icon chat"></span>' +\
 '<span class="activity-text">' +\
 '<span class="presenter-label">PRESENTER</span>' +\
 '<span class="accent">' + msg.presenter + ':</span> ' + safeMsg +\
 '</span>' +\
 '<span class="activity-time">now</span>';\
\
 feed.insertBefore(div, feed.firstChild);\
\
 // Keep feed trimmed\
 while (feed.children.length > 15) \{\
 feed.removeChild(feed.lastChild);\
 \}\
\}\
