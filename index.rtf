 // Helper: set textContent only if element exists (defensive against missing IDs)\
 var setText = function(id, value) \{\
 var el = document.getElementById(id);\
 if (el) el.textContent = value;\
 \};\
 var setSrc = function(id, value) \{\
 var el = document.getElementById(id);\
 if (el) el.src = value;\
 \};\
\
 setText('onAirShow', displayName);\
 setText('onAirHost', displayHost);\
 setSrc('onAirImg', displayImg);\
 setText('onAirTime', formatTime(hour) + ' ' + formatTime(nextHour));\
\
 // Show ramp-up: listeners build from ~30% to full over first 5 minutes \
 var now = new Date();\
 var estMinStr = now.toLocaleString('en-US', \{\
 timeZone: 'America/New_York',\
 hour12: false, minute: '2-digit'\
 \});\
 var minsIntoShow = parseInt(estMinStr) || 0;\
 var secsIntoShow = now.getSeconds();\
 var totalSecsIntoShow = minsIntoShow * 60 + secsIntoShow;\
\
 // Ramp factor: 0.30 at start 1.0 at 5 minutes (300s), smooth easing\
 var rampSecs = 300;\
 var rampFactor;\
 if (totalSecsIntoShow >= rampSecs) \{\
 rampFactor = 1.0;\
 \} else \{\
 var t = totalSecsIntoShow / rampSecs;\
 // Ease-out curve for natural feel\
 var ease = 1 - Math.pow(1 - t, 2);\
 rampFactor = 0.30 + (0.70 * ease);\
 \}\
