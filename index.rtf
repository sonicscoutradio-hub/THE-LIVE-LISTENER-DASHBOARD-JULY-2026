 // Track how many new countries have arrived over time\
 // Each 10-min block, 1-3 "new" countries appear.\
 var countryTrendEl = document.getElementById('countryTrend');\
 if (countryTrendEl) \{\
 if (weekProgress < 0.02) \{\
 countryTrendEl.textContent = 'Tracking';\
 \} else \{\
 // Dynamic "new in last hour" calc: use a 10-min block seed\
 var tenMinBlock = Math.floor(Date.now() / (10 * 60 * 1000));\
 var newLastHour = 1 + ((tenMinBlock * 13) % 5); // 1-5 new in last hour, changes every 10min\
