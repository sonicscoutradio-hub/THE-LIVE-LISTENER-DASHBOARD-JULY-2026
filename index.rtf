// Equirectangular projection calibrated for Wikimedia BlankMap rendering\
// The map image has a viewBox of 2000x1001 and uses standard equirectangular,\
// but object-fit:contain centers the image in our 1000x500 SVG container.\
// Since both aspect ratios are 2:1, no letterboxing occurs.\
// Empirically tuned so real cities land on their actual locations.\
// Deterministic variance % per city (range -9 to +15, weighted toward positive)\
function getVariance(cityName) \{\
 var hash = 0;\
 for (var i = 0; i < cityName.length; i++) \{\
 hash = ((hash << 5) - hash) + cityName.charCodeAt(i);\
 hash |= 0;\
 \}\
 var raw = Math.abs(hash) % 25;\
 return raw - 9;\
\}\
