// RENDER ON AIR \
function renderOnAir() \{\
 var cs = getCurrentShow();\
 var show = cs.show;\
 var hour = cs.hour;\
 var nextHour = (hour + 1) % 24;\
\
 // If RadioCult reports a different show is live, prefer that (source of truth)\
 var displayName = show.name;\
 var displayHost = show.host;\
 var displayImg = PRESENTER_IMAGES[show.img] || '';\
 if (_liveShowFromApi) \{\
 // Try to find a matching show in our SHOWS array by name (case-insensitive).\
 // We deliberately ignore Coming Soon shows here -- if the API still reports\
 // an old show name that we have since flagged as inactive, we do not want\
 // to display its stale info as if it is airing now.\
 // Legacy / renamed show aliases  maps old API names to current show IDs.\
 // If RadioCult (or the Google Sheet) still reports the old show name,\
 // we redirect it to the correct current show entry.\
 var SHOW_NAME_ALIASES = \{\
 'in the nova': 'downtime_discovery',\
 'in the nova with don': 'downtime_discovery',\
 'downtime discovery': 'downtime_discovery',\
 'downtime with don wayne':'downtime'\
 \};\
 var apiNameLower = _liveShowFromApi.toLowerCase();\
 // Check alias table first\
 var aliasId = null;\
 for (var aliasKey in SHOW_NAME_ALIASES) \{\
 if (apiNameLower.indexOf(aliasKey) !== -1) \{\
 aliasId = SHOW_NAME_ALIASES[aliasKey];\
 break;\
 \}\
 \}\
 var matched = aliasId\
 ? SHOWS.find(function(s) \{ return s.id === aliasId; \})\
 : SHOWS.find(function(s) \{\
 if (s.comingSoon) return false;\
 return s.name.toLowerCase() === apiNameLower ||\
 apiNameLower.indexOf(s.name.toLowerCase()) !== -1 ||\
 s.name.toLowerCase().indexOf(apiNameLower) !== -1;\
 \});\
 if (matched) \{\
 displayName = matched.name;\
 displayHost = matched.host;\
 displayImg = PRESENTER_IMAGES[matched.img] || '';\
 \}\
 // If the API reports something that does not match a live show, we\
 // intentionally KEEP the schedule-derived show name/host/image. This\
 // prevents the dashboard from blurting out raw API boilerplate text\
 // (e.g. stale "Wren Weathers - The Edge of the Universe (+++ tagline)"\
 // strings that the streaming platform may not have cleared yet).\
 \}\
