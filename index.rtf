// PLATFORM STREAMS (iOS + Android + Web) \
// MUST SUM TO Current Live Listeners (liveCount element)\
// Split: Web ~75%, iOS ~15%, Android ~10%\
function updatePlatformStreams() \{\
 var iosEl = document.getElementById('iosStreams');\
 var andEl = document.getElementById('androidStreams');\
 var webEl = document.getElementById('webStreams');\
 if (!iosEl || !andEl || !webEl) return;\
\
 // Get the current live listener count as the source of truth\
 var liveEl = document.getElementById('liveCount');\
 var total = parseInt(liveEl ? liveEl.textContent : '0') || 0;\
\
 if (total <= 0) \{\
 iosEl.textContent = 0;\
 andEl.textContent = 0;\
 webEl.textContent = 0;\
 return;\
 \}\
\
 // Slow, organic drift in shares  keeps mix roughly: Web 75% / iOS 15% / Android 10%\
 // with small natural fluctuation so the numbers feel alive\
 var now = Date.now();\
 // iOS: 13% to 17% (center 15%)\
 var iosShare = 0.15 + Math.sin(now / 45000) * 0.02 + Math.sin(now / 18000) * 0.01;\
 // Android: 8% to 12% (center 10%)\
 var androidShare = 0.10 + Math.sin(now / 55000) * 0.015 + Math.sin(now / 22000) * 0.008;\
 // Clamp for safety\
 iosShare = Math.max(0.12, Math.min(0.18, iosShare));\
 androidShare = Math.max(0.07, Math.min(0.13, androidShare));\
\
 var ios = Math.round(total * iosShare);\
 var android = Math.round(total * androidShare);\
 var web = total - ios - android; // remainder  guarantees perfect sum\
\
 // Safety: never negative web\
 if (web < 0) \{\
 if (android > 0) \{ android += web; web = 0; \}\
 else \{ ios += web; web = 0; \}\
 \}\
\
 // Enforce natural order: Web > iOS > Android\
 if (ios > web) \{\
 var t = web; web = ios; ios = t;\
 \}\
 if (android > ios) \{\
 var t2 = ios; ios = android; android = t2;\
 \}\
\
 iosEl.textContent = ios;\
 andEl.textContent = android;\
 webEl.textContent = web;\
\}\
// Initial + every 8 seconds\
setTimeout(updatePlatformStreams, 500);\
setInterval(updatePlatformStreams, 8000);\
