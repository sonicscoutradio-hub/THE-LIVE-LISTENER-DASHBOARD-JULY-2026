.recently-played-list::-webkit-scrollbar-track \{ background: rgba(0,0,0,.2); \}\
.recently-played-list::-webkit-scrollbar-thumb \{ background: var(--amber-dm); border-radius: 2px; \}\
.recently-played-list::-webkit-scrollbar-thumb:hover \{ background: var(--amber); \}\
\
/* ============================================================\
   HEART CHART (replaces Recently Played)\
   ============================================================ */\
.heart-chart-section \{\
  margin-top: 18px;\
  padding-top: 14px;\
  border-top: 1px dashed rgba(232,112,10,0.22);\
\}\
.heart-chart-header \{\
  display: flex;\
  align-items: baseline;\
  justify-content: space-between;\
  margin-bottom: 8px;\
\}\
.heart-chart-title \{\
  font-family: 'Syne', sans-serif;\
  font-weight: 700;\
  font-size: 14px;\
  color: var(--amber-br);\
  letter-spacing: -0.01em;\
\}\
.heart-chart-meta \{\
  font-size: 9px;\
  letter-spacing: 0.25em;\
  color: var(--text);\
  text-transform: uppercase;\
\}\
.heart-chart-blurb \{\
  font-size: 11.5px;\
  color: var(--text-dm);\
  line-height: 1.55;\
  margin: 0 0 12px;\
\}\
.heart-chart-blurb strong \{ color: var(--amber-br); font-weight: 700; \}\
.heart-chart-list \{\
  display: flex;\
  flex-direction: column;\
  gap: 6px;\
  margin-bottom: 12px;\
\}\
.heart-chart-row \{\
  display: grid;\
  grid-template-columns: 22px 1fr auto;\
  gap: 10px;\
  align-items: center;\
  padding: 7px 10px;\
  background: rgba(232,112,10,0.05);\
  border: 1px solid rgba(232,112,10,0.15);\
  border-radius: 4px;\
\}\
.heart-chart-row.top \{ background: rgba(232,112,10,0.10); border-color: rgba(232,112,10,0.35); \}\
.heart-chart-rank \{\
  font-family: 'JetBrains Mono', monospace;\
  font-weight: 700;\
  font-size: 13px;\
  color: var(--amber);\
  text-align: center;\
\}\
.heart-chart-row.top .heart-chart-rank \{ color: var(--amber-br); \}\
.heart-chart-track \{\
  display: flex;\
  flex-direction: column;\
  min-width: 0;\
\}\
.heart-chart-track-title \{\
  font-family: 'Syne', sans-serif;\
  font-weight: 700;\
  font-size: 12.5px;\
  color: var(--text);\
  overflow: hidden;\
  text-overflow: ellipsis;\
  white-space: nowrap;\
\}\
.heart-chart-track-artist \{\
  font-family: 'JetBrains Mono', monospace;\
  font-size: 10px;\
  letter-spacing: 0.08em;\
  color: var(--text-dm);\
  text-transform: uppercase;\
  margin-top: 2px;\
  overflow: hidden;\
  text-overflow: ellipsis;\
  white-space: nowrap;\
\}\
.heart-chart-hearts \{\
  display: inline-flex;\
  align-items: center;\
  gap: 4px;\
  font-family: 'JetBrains Mono', monospace;\
  font-weight: 700;\
  font-size: 12px;\
  color: var(--live);\
\}\
.heart-chart-hearts .heart-icon \{ font-size: 13px; line-height: 1; \}\
.heart-chart-empty \{\
  padding: 16px 12px;\
  text-align: center;\
  color: var(--text-dm);\
  font-size: 11px;\
\}\
.heart-chart-prize \{\
  display: flex;\
  align-items: center;\
  gap: 8px;\
  padding: 8px 12px;\
  background: rgba(255,56,96,0.06);\
  border: 1px dashed rgba(255,56,96,0.30);\
  border-radius: 4px;\
  font-family: 'JetBrains Mono', monospace;\
  font-size: 10px;\
  letter-spacing: 0.12em;\
  color: var(--text-dm);\
  text-transform: uppercase;\
\}\
.heart-chart-prize-icon \{ color: var(--live); font-size: 13px; \}\
\
\
.recently-empty \{\
 padding: 24px 16px;\
 text-align: center;\
 color: #ff5060;\
 font-size: 12px;\
\}\
.recently-empty-icon \{\
 display: block;\
 font-size: 32px;\
 color: #ff5060;\
 opacity: 0.8;\
 margin-bottom: 8px;\
 animation: heart-pulse 2.5s ease-in-out infinite;\
\}\
.recently-empty-text \{\
 font-size: 11px;\
 letter-spacing: 0.08em;\
 color: #ff5060;\
\}\
\
.recently-row \{\
 display: grid;\
 grid-template-columns: 50px 1fr auto;\
 gap: 10px;\
 align-items: center;\
 padding: 8px 10px;\
 background: rgba(0,0,0,.2);\
 border-left: 2px solid rgba(232,112,10,.15);\
 transition: all .15s;\
 animation: rec-slide .35s ease;\
\}\
.recently-row:hover \{\
 background: rgba(232,112,10,.05);\
 border-left-color: var(--amber);\
\}\
.recently-row.is-current \{\
 background: rgba(232,112,10,.1);\
 border-left-color: var(--amber-br);\
\}\
.recently-row.is-current .recently-time \{\
 color: var(--green);\
\}\
@keyframes rec-slide \{\
 from \{ opacity: 0; transform: translateY(-4px); \}\
 to \{ opacity: 1; transform: translateY(0); \}\
\}\
.recently-time \{\
 font-family: 'JetBrains Mono', monospace;\
 font-size: 10px;\
 color: var(--text);\
 letter-spacing: 0.05em;\
 white-space: nowrap;\
\}\
.recently-info \{\
 min-width: 0;\
\}\
.recently-title \{\
 font-family: 'Syne', sans-serif;\
 font-weight: 700;\
 font-size: 13px;\
 color: var(--text);\
 white-space: nowrap;\
 overflow: hidden;\
 text-overflow: ellipsis;\
\}\
.recently-artist \{\
 font-size: 11px;\
 color: var(--amber-br);\
 white-space: nowrap;\
 overflow: hidden;\
 text-overflow: ellipsis;\
\}\
.recently-show \{\
 font-size: 9px;\
 color: var(--text);\
 letter-spacing: 0.1em;\
 text-transform: uppercase;\
 white-space: nowrap;\
 text-align: right;\
\}\
.recently-heart-btn \{\
 background: transparent;\
 border: 1px solid rgba(232,112,10,.3);\
 color: var(--amber);\
 font-size: 14px;\
 width: 28px; height: 28px;\
 border-radius: 50%;\
 cursor: pointer;\
 transition: all .15s;\
 display: flex;\
 align-items: center;\
 justify-content: center;\
 padding: 0;\
 flex-shrink: 0;\
\}\
.recently-heart-btn:hover \{\
 border-color: var(--amber);\
 background: rgba(232,112,10,.1);\
 transform: scale(1.1);\
\}\
.recently-heart-btn.hearted \{\
 background: rgba(255,80,96,.18);\
 border-color: #ff4060;\
 color: #ff4060;\
\}\
.recently-heart-btn.hearted:hover \{\
 cursor: default;\
 transform: none;\
\}\
\
.empty-hearts \{\
 padding:40px 20px;\
 text-align:center;\
 color:#ff5060;\
\}\
.empty-hearts-icon \{\
 font-size:48px;\
 color:#ff5060;\
 margin-bottom:14px;\
 opacity:0.85;\
 animation: heart-pulse 2.5s ease-in-out infinite;\
\}\
@keyframes heart-pulse \{\
 0%, 100% \{ transform: scale(1); opacity: 0.85; \}\
 50% \{ transform: scale(1.1); opacity: 1; \}\
\}\
.empty-hearts-title \{\
 font-family: 'Syne', sans-serif;\
 font-weight: 700;\
 font-size: 14px;\
 color: #ff5060;\
 margin-bottom: 6px;\
\}\
.empty-hearts-sub \{\
 font-size: 11px;\
 letter-spacing: 0.05em;\
 color: #ff5060;\
\}\
.track-row \{\
 display:grid;\
 grid-template-columns:22px 44px 1fr auto;\
 gap:10px;\
 padding:10px;\
 background:rgba(0,0,0,.25);\
 border:1px solid rgba(232,112,10,.12);\
 align-items:center;\
 transition:all .2s;\
\}\
.track-row:hover \{\
 border-color:var(--amber);\
 background:rgba(232,112,10,.05);\
 transform:translateX(2px);\
\}\
.track-rank \{\
 font-family:'Syne',sans-serif;\
 font-size:22px;\
 font-weight:800;\
 color:var(--amber);\
 line-height:1;\
 text-align:center;\
\}\
.track-art \{\
 width:44px;\
 height:44px;\
 border:1px solid var(--amber-dm);\
 overflow:hidden;\
 flex-shrink:0;\
\}\
.track-art img \{\
 width:100%;\
 height:100%;\
 object-fit:cover;\
 display:block;\
\}\
.track-info \{\
 min-width:0;\
 overflow:hidden;\
\}\
.track-title \{\
 font-family:'Syne',sans-serif;\
 font-weight:700;\
 font-size:13px;\
 color:var(--text);\
 line-height:1.2;\
 white-space:nowrap;\
 overflow:hidden;\
 text-overflow:ellipsis;\
\}\
.track-artist \{\
 font-size:11px;\
 color:var(--text-dm);\
 margin-top:2px;\
 white-space:nowrap;\
 overflow:hidden;\
 text-overflow:ellipsis;\
\}\
.track-show \{\
 font-family:'JetBrains Mono',monospace;\
 font-size:8px;\
 color:var(--amber);\
 letter-spacing:.15em;\
 text-transform:uppercase;\
 margin-top:4px;\
\}\
.track-plays \{\
 font-family:'JetBrains Mono',monospace;\
 font-size:10px;\
 color:var(--amber-br);\
 font-weight:600;\
 text-align:right;\
 white-space:nowrap;\
\}\
.track-plays-label \{\
 font-size:8px;\
 color:var(--text-dm);\
 letter-spacing:.15em;\
 text-transform:uppercase;\
\}\
\
/* Heart button on each track row */\
.track-heart-btn \{\
 display:flex;\
 flex-direction:column;\
 align-items:center;\
 justify-content:center;\
 gap:2px;\
 min-width:46px;\
 padding:6px 8px;\
 background:rgba(232,112,10,.06);\
 border:1px solid var(--amber-dm);\
 border-radius:6px;\
 color:var(--amber);\
 cursor:pointer;\
 transition:all .15s;\
 font-family:inherit;\
\}\
.track-heart-btn:hover \{\
 background:rgba(232,112,10,.14);\
 border-color:var(--amber);\
 transform:scale(1.05);\
\}\
.track-heart-btn:active \{\
 transform:scale(0.95);\
\}\
.track-heart-btn.hearted \{\
 background:rgba(232,112,10,.22);\
 border-color:var(--amber);\
 color:var(--amber-br);\
\}\
.track-heart-btn.hearted .heart-icon \{\
 color:#ff4060;\
 animation:heartPulse .4s ease;\
\}\
.track-heart-btn .heart-icon \{\
 font-size:16px;\
 line-height:1;\
 color:var(--amber);\
 transition:color .15s, transform .15s;\
\}\
.track-heart-btn .track-heart-count \{\
 font-family:'JetBrains Mono',monospace;\
 font-size:10px;\
 font-weight:700;\
 letter-spacing:.03em;\
 color:var(--amber-br);\
\}\
@keyframes heartPulse \{\
 0% \{ transform:scale(1); \}\
 50% \{ transform:scale(1.5); \}\
 100% \{ transform:scale(1); \}\
\}\
.tracks-footer \{\
 margin-top:auto;\
 display:flex;\
 align-items:center;\
 gap:8px;\
 padding-top:10px;\
 border-top:1px dashed rgba(232,112,10,.2);\
 font-family:'JetBrains Mono',monospace;\
 font-size:10px;\
 color:var(--text-dm);\
 letter-spacing:.1em;\
\}\
.tracks-dot \{\
 width:6px; height:6px;\
 border-radius:50%;\
 background:var(--green);\
 box-shadow:0 0 8px var(--green);\
 animation:pulse-live 2s ease-in-out infinite;\
\}\
\
/* SUBSCRIPTIONS PANEL */\
.tier-image-wrap \{\
 display:flex;\
 justify-content:center;\
 padding:6px 0;\
\}\
.tier-image \{\
 max-width:100%;\
 width:260px;\
 height:auto;\
 border:1px solid var(--amber-dm);\
 border-radius:4px;\
 box-shadow:0 8px 24px rgba(0,0,0,.5), 0 0 20px rgba(232,112,10,.1);\
\}\
.tier-cards \{\
 display:flex;\
 flex-direction:column;\
 gap:10px;\
 margin-top:4px;\
\}\
.tier-card \{\
 padding:14px 16px;\
 border:1px solid var(--amber-dm);\
 background:rgba(0,0,0,.3);\
 position:relative;\
 overflow:hidden;\
\}\
.tier-card.tier-1 \{\
 background:linear-gradient(135deg, rgba(232,112,10,.18), rgba(0,0,0,.3) 80%);\
 border-color:var(--amber);\
\}\
.tier-card.tier-2 \{\
 background:linear-gradient(135deg, rgba(232,112,10,.08), rgba(0,0,0,.3) 80%);\
\}\
.tier-label \{\
 font-family:'JetBrains Mono',monospace;\
 font-size:9px;\
 letter-spacing:.3em;\
 color:var(--amber);\
 font-weight:700;\
\}\
.tier-name \{\
 font-family:'Syne',sans-serif;\
 font-size:15px;\
 font-weight:700;\
 color:var(--text);\
 margin-top:2px;\
\}\
.tier-price \{\
 font-family:'Syne',sans-serif;\
 font-size:26px;\
 font-weight:800;\
 color:var(--amber-br);\
 line-height:1;\
 margin-top:8px;\
 letter-spacing:-.02em;\
\}\
.tier-price-unit \{\
 font-size:11px;\
 color:var(--text-dm);\
 font-weight:400;\
 letter-spacing:0;\
 margin-left:2px;\
\}\
.tier-purpose \{\
 font-size:11px;\
 color:var(--text-dm);\
 margin-top:8px;\
 line-height:1.4;\
 font-style:italic;\
\}\
.tier-features \{\
 list-style:none;\
 padding:0;\
 margin:10px 0 0;\
 display:flex;\
 flex-direction:column;\
 gap:6px;\
\}\
.tier-features li \{\
 font-size:11px;\
 color:var(--text);\
 padding-left:16px;\
 position:relative;\
 line-height:1.4;\
\}\
.tier-features li::before \{\
 content:'';\
 position:absolute;\
 left:0;\
 top:0;\
 color:var(--amber);\
 font-weight:700;\
\}\
.tier-cta \{\
 margin-top:10px;\
 padding:10px 12px;\
 background:rgba(232,112,10,.08);\
 border:1px dashed var(--amber);\
 display:flex;\
 flex-direction:column;\
 gap:2px;\
 text-align:center;\
\}\
.tier-cta-label \{\
 font-family:'JetBrains Mono',monospace;\
 font-size:9px;\
 letter-spacing:.2em;\
 color:var(--amber);\
 text-transform:uppercase;\
\}\
.tier-cta-date \{\
 font-family:'Syne',sans-serif;\
 font-size:13px;\
 font-weight:700;\
 color:var(--amber-br);\
\}\
\
/* Mobile responsive for info-grid */\
@media (max-width: 900px) \{\
 .info-grid \{ grid-template-columns:1fr; gap:14px; \}\
 .info-panel \{ min-height:auto; \}\
 .schedule-list \{ max-height:420px; \}\
\}\
\
\
.upcoming-section \{\
 border-top:1px solid var(--amber-dm);\
 padding:12px 18px 16px;\
 background:rgba(232,112,10,.02);\
\}\
.upcoming-header \{\
 font-family:'JetBrains Mono',monospace; font-size:9px;\
 letter-spacing:.3em; color:var(--amber);\
 text-transform:uppercase; margin-bottom:10px;\
\}\
.upcoming-list \{\
 display:flex; flex-direction:column; gap:6px;\
\}\
.upcoming-item \{\
 display:flex; align-items:center; gap:10px;\
 padding:8px 10px;\
 background:rgba(0,0,0,.2);\
 border:1px solid rgba(232,112,10,.15);\
 transition:all .3s ease;\
\}\
.upcoming-item:hover \{ border-color:var(--amber); background:rgba(232,112,10,.06); \}\
.upcoming-art \{\
 width:38px; height:38px;\
 border:1px solid var(--amber-dm);\
 overflow:hidden; flex-shrink:0;\
\}\
.upcoming-art img \{ width:100%; height:100%; object-fit:cover; display:block; \}\
.upcoming-info \{ flex:1; min-width:0; \}\
.upcoming-show \{\
 font-family:'Syne',sans-serif; font-weight:700;\
 font-size:13px; color:var(--text); line-height:1.2;\
 white-space:nowrap; overflow:hidden; text-overflow:ellipsis;\
\}\
.upcoming-host \{\
 font-family:'JetBrains Mono',monospace;\
 font-size:9px; letter-spacing:.15em;\
 color:var(--amber); text-transform:uppercase;\
 margin-top:2px;\
 white-space:nowrap; overflow:hidden; text-overflow:ellipsis;\
\}\
.upcoming-time \{\
 font-family:'JetBrains Mono',monospace;\
 font-size:11px; color:var(--text);\
 font-weight:500;\
 text-align:right;\
 white-space:nowrap;\
\}\
.upcoming-time-lbl \{\
 font-size:8px; color:var(--text);\
 letter-spacing:.2em; text-transform:uppercase;\
 margin-top:1px;\
\}\
/* "Coming Soon" pill that replaces the countdown label for shows\
 that are scheduled but flagged as Coming Soon in the sheet. */\
.upcoming-coming-soon \{\
 display:inline-block;\
 margin-top:3px;\
 padding:2px 7px;\
 font-family:'JetBrains Mono',monospace;\
 font-size:8px;\
 letter-spacing:.18em;\
 text-transform:uppercase;\
 color:#ffd28a;\
 background:rgba(232,112,10,.16);\
 border:1px solid rgba(232,112,10,.5);\
 border-radius:3px;\
 white-space:nowrap;\
\}\
.upcoming-item.is-coming-soon \{ opacity:.82; \}\
.upcoming-item.is-coming-soon .upcoming-show \{ color:var(--text); \}\
.upcoming-item.is-coming-soon .upcoming-time \{ color:var(--amber); \}\
\
/* Map country labels */\
.map-label \{\
 font-family:'JetBrains Mono',monospace;\
 font-size:10px;\
 fill:rgba(255,220,180,.85);\
 font-weight:600;\
 letter-spacing:.15em;\
 text-anchor:middle;\
 pointer-events:none;\
 text-transform:uppercase;\
 paint-order:stroke;\
 stroke:rgba(0,0,0,.6);\
 stroke-width:2px;\
 stroke-linejoin:round;\
\}\
.map-label.small \{ font-size:8.5px; \}\
.map-label.tiny \{ font-size:7px; letter-spacing:.08em; fill:rgba(255,220,180,.65); \}\
\
/* Now Playing (RadioCult embed) */\
.nowplaying-panel \{\
 display:flex; flex-direction:column;\
 flex:1; min-height:0;\
\}\
.nowplaying-body \{\
 padding:14px 18px 10px;\
 background:rgba(232,112,10,.04);\
 border-bottom:1px solid var(--amber-dm);\
\}\
.nowplaying-body iframe \{\
 display:block;\
 width:100%;\
\}\
.np-track-display \{\
 display:flex;\
 flex-direction:column;\
 gap:3px;\
 min-height:40px;\
 justify-content:center;\
\}\
.np-track-title \{\
 font-family:'Syne',sans-serif;\
 font-weight:700;\
 font-size:15px;\
 color:var(--amber-br);\
 letter-spacing:-.01em;\
 line-height:1.2;\
 white-space:nowrap;\
 overflow:hidden;\
 text-overflow:ellipsis;\
\}\
.np-track-artist \{\
 font-family:'JetBrains Mono',monospace;\
 font-size:11px;\
 color:var(--text);\
 letter-spacing:.05em;\
 white-space:nowrap;\
 overflow:hidden;\
 text-overflow:ellipsis;\
\}\
.activity-divider \{\
 padding:10px 18px 6px;\
 font-family:'JetBrains Mono',monospace; font-size:9px;\
 letter-spacing:.3em; color:var(--amber);\
 text-transform:uppercase;\
\}\
\
\
/* Full web player */\
.player-body \{\
 padding:6px 18px 14px;\
 background:linear-gradient(180deg, rgba(232,112,10,.04), transparent);\
\}\
.player-iframe-wrap \{\
 position:relative;\
\}\
.nowplaying-iframe-wrap \{\
 position:relative;\
\}\
\
/* SSR logo overlay - sits on top of RadioCult's heart icon in the square player\
 (RadioCult heart is at bottom-right, in the track info row beneath the artwork) */\
.ssr-logo-overlay \{\
 position:absolute;\
 bottom:14px;\
 right:14px;\
 width:30px;\
 height:30px;\
 border-radius:50%;\
 cursor:pointer;\
 z-index:10;\
 background:radial-gradient(circle, rgba(232,112,10,.95) 0%, rgba(232,112,10,.8) 60%, rgba(232,112,10,.5) 100%);\
 border:2px solid var(--amber-br);\
 display:flex;\
 align-items:center;\
 justify-content:center;\
 font-family:'Syne',sans-serif;\
 font-weight:900;\
 font-size:8px;\
 letter-spacing:.05em;\
 color:#fff;\
 text-decoration:none;\
 box-shadow:0 2px 10px rgba(0,0,0,.7), 0 0 0 0 rgba(232,112,10,.5);\
 transition:all .2s;\
\}\
.ssr-logo-overlay:hover \{\
 transform:scale(1.1);\
 box-shadow:0 2px 12px rgba(0,0,0,.6), 0 0 0 6px rgba(232,112,10,.25);\
 background:radial-gradient(circle, var(--amber-br) 0%, var(--amber) 60%, transparent 100%);\
\}\
.ssr-logo-mark \{\
 line-height:1;\
 pointer-events:none;\
\}\
\
/* Platform streams (iOS + Android + Web live count  must sum to Current Live Listeners) */\
.platform-streams \{\
 display:grid;\
 grid-template-columns:1fr 1fr 1fr;\
 gap:6px;\
 margin-top:8px;\
\}\
\
/* VIBE SECTION (Globe  full width) */\
.vibe-section \{\
 margin-top: 12px;\
 padding: 12px;\
 background: rgba(232,112,10,.04);\
 border: 1px solid var(--amber-dm);\
 border-radius: 6px;\
\}\
.vibe-globe-wrap-full \{\
 padding: 6px 8px;\
 display: flex;\
 flex-direction: column;\
\}\
.vibe-eyebrow \{\
 display: flex; align-items: center; gap: 6px;\
 font-size: 9px; letter-spacing: 0.22em;\
 color: var(--amber); text-transform: uppercase;\
 font-weight: 700; margin-bottom: 8px;\
\}\
.vibe-dot \{\
 width: 5px; height: 5px;\
 background: var(--amber); border-radius: 50%;\
 animation: pulse-live 2s ease-in-out infinite;\
\}\
#vibeGlobe \{\
 width: 100%; height: 460px;\
\}\
.vibe-globe-legend \{\
 margin-top: 6px;\
 padding-top: 8px;\
 border-top: 1px dashed rgba(232,112,10,0.18);\
 display: flex;\
 justify-content: space-between;\
 align-items: center;\
 font-size: 10px;\
\}\
.vibe-legend-text \{\
 color: var(--text);\
 letter-spacing: 0.04em;\
 font-style: italic;\
\}\
.vibe-legend-count \{\
 color: var(--amber-br);\
 font-family: 'JetBrains Mono', monospace;\
 font-weight: 700;\
 letter-spacing: 0.05em;\
\}\
.vibe-globe-base \{\
 fill: #0a0806;\
 stroke: var(--amber-dm);\
 stroke-width: 0.6;\
\}\
.vibe-globe-graticule \{\
 fill: none;\
 stroke: rgba(232,112,10,0.25);\
 stroke-width: 0.4;\
\}\
/* Layer 1  background simulated dots */\
.vibe-bg-dot \{\
 fill: var(--sky);\
 filter: drop-shadow(0 0 2px rgba(78,168,222,0.5));\
\}\
/* Layer 2  live activity dots (light blue, slightly larger and brighter) */\
.vibe-live-dot \{\
 fill: var(--sky);\
 filter: drop-shadow(0 0 4px rgba(78,168,222,0.9));\
\}\
.vibe-globe-viewer \{\
 fill: #ffffff;\
 filter: drop-shadow(0 0 5px #fff) drop-shadow(0 0 10px rgba(255,255,255,0.5));\
\}\
.vibe-globe-pulse \{\
 fill: none;\
 stroke: var(--amber-br);\
 stroke-width: 1;\
 opacity: 0;\
 transform-origin: center center;\
\}\
@keyframes vibe-pulse \{\
 0% \{ transform: scale(0.5); opacity: 1; \}\
 100% \{ transform: scale(3.5); opacity: 0; \}\
\}\
.platform-card \{\
 display:flex;\
 align-items:center;\
 gap:6px;\
 padding:7px 8px;\
 background:rgba(232,112,10,.06);\
 border:1px solid var(--amber-dm);\
 border-radius:6px;\
 transition:background .2s;\
 min-width:0;\
\}\
.platform-card:hover \{\
 background:rgba(232,112,10,.12);\
\}\
.platform-icon, .platform-icon-android, .platform-icon-web \{\
 width:22px; height:22px;\
 flex-shrink:0;\
 background-repeat:no-repeat;\
 background-position:center;\
 background-size:contain;\
\}\
.platform-icon \{\
 /* iOS / Apple silhouette */\
 background-image:url("data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 24 24' fill='%23ffa030'><path d='M17.05 20.28c-.98.95-2.05.8-3.08.35-1.09-.46-2.09-.48-3.24 0-1.44.62-2.2.44-3.06-.35C2.79 15.25 3.51 7.59 9.05 7.31c1.35.07 2.29.74 3.08.8 1.18-.24 2.31-.93 3.57-.84 1.51.12 2.65.72 3.4 1.8-3.12 1.87-2.38 5.98.48 7.13-.57 1.5-1.31 2.99-2.54 4.09zM12.03 7.25c-.15-2.23 1.66-4.07 3.74-4.25.29 2.58-2.34 4.5-3.74 4.25z'/></svg>");\
\}\
