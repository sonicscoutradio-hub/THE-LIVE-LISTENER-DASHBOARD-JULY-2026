/* ===== PROMO BANNER ===== */\
.promo-banner \{\
 margin: 0 0 0 0;\
 padding: 0 28px;\
 margin-top: 18px;\
\}\
.promo-card \{\
 background: linear-gradient(135deg, rgba(232,112,10,0.12) 0%, rgba(232,112,10,0.04) 100%);\
 border: 1px solid rgba(232,112,10,0.3);\
 border-radius: 10px;\
 padding: 16px 20px;\
 display: flex;\
 align-items: center;\
 gap: 16px;\
 min-height: 68px;\
 position: relative;\
 overflow: hidden;\
\}\
.promo-card::before \{\
 content: '';\
 position: absolute;\
 left: 0; top: 0; bottom: 0;\
 width: 4px;\
 background: var(--amber);\
 border-radius: 10px 0 0 10px;\
\}\
.promo-icon \{ font-size: 1.8rem; flex-shrink: 0; \}\
.promo-text \{ flex: 1; min-width: 0; \}\
.promo-eyebrow \{\
 font-size: 0.65rem;\
 letter-spacing: 0.15em;\
 text-transform: uppercase;\
 color: var(--amber);\
 margin-bottom: 3px;\
\}\
.promo-headline \{\
 font-size: 0.95rem;\
 font-weight: 700;\
 color: var(--text-primary);\
 white-space: nowrap;\
 overflow: hidden;\
 text-overflow: ellipsis;\
\}\
.promo-sub \{\
 font-size: 0.75rem;\
 color: var(--text-muted);\
 margin-top: 2px;\
\}\
.promo-dots \{\
 display: flex;\
 gap: 5px;\
 margin-left: 12px;\
 flex-shrink: 0;\
\}\
.promo-dot \{\
 width: 7px; height: 7px;\
 border-radius: 50%;\
 background: rgba(232,112,10,0.25);\
 cursor: pointer;\
 transition: background 0.2s;\
\}\
.promo-dot.active \{ background: var(--amber); \}\
@media(max-width:600px)\{\
 .promo-banner \{ padding: 0 14px; \}\
 .promo-headline \{ font-size: 0.85rem; \}\
\}\
\
\
/* Removed: Featured Track / Artist card CSS */\
/* ===== MILESTONE RUNNER ===== */\
.runner-lane \{\
 position: relative;\
 height: 52px;\
 margin-bottom: 4px;\
 overflow: visible;\
\}\
.runner-wrap \{\
 position: absolute;\
 bottom: 0;\
 transform: translateX(-50%);\
 transition: left 1.3s cubic-bezier(.22,.68,0,1.2);\
 display: flex;\
 flex-direction: column;\
 align-items: center;\
 z-index: 2;\
\}\
.runner-svg \{\
 width: 34px;\
 height: 46px;\
 /* Running bob  slight vertical bounce */\
 animation: runnerBob 0.45s ease-in-out infinite alternate;\
 filter: drop-shadow(0 2px 4px rgba(232,112,10,0.4));\
\}\
@keyframes runnerBob \{\
 from \{ transform: translateY(0px) rotate(-2deg); \}\
 to \{ transform: translateY(-3px) rotate(2deg); \}\
\}\
/* Arm/leg stride animation */\
.runner-svg .arm-back \{ animation: armStride 0.45s ease-in-out infinite alternate; transform-origin: 17px 27px; \}\
.runner-svg .arm-fwd \{ animation: armStride 0.45s ease-in-out infinite alternate-reverse; transform-origin: 17px 27px; \}\
.runner-svg .leg-back \{ animation: legStride 0.45s ease-in-out infinite alternate; transform-origin: 17px 34px; \}\
.runner-svg .leg-fwd \{ animation: legStride 0.45s ease-in-out infinite alternate-reverse; transform-origin: 17px 34px; \}\
@keyframes armStride \{\
 from \{ transform: rotate(-18deg); \}\
 to \{ transform: rotate(18deg); \}\
\}\
@keyframes legStride \{\
 from \{ transform: rotate(-22deg); \}\
 to \{ transform: rotate(22deg); \}\
\}\
\
/* Pause animations when milestone reached */\
.runner-svg.at-goal \{ animation: none; \}\
.runner-svg.at-goal .arm-back,\
.runner-svg.at-goal .arm-fwd,\
.runner-svg.at-goal .leg-back,\
.runner-svg.at-goal .leg-fwd \{ animation: none; \}\
\
/* Jump animation at goal */\
.runner-wrap.jumping .runner-svg \{\
 animation: runnerJump 0.7s cubic-bezier(.22,.68,0,1.2) forwards !important;\
\}\
@keyframes runnerJump \{\
 0% \{ transform: translateY(0) scaleX(1) rotate(0deg); \}\
 35% \{ transform: translateY(-28px) scaleX(1.1) rotate(-8deg); \}\
 65% \{ transform: translateY(-28px) scaleX(1.1) rotate(8deg); \}\
 85% \{ transform: translateY(-6px) scaleX(0.95) rotate(0deg); \}\
 100% \{ transform: translateY(0) scaleX(1) rotate(0deg); \}\
\}\
\
/* Yeah! bubble */\
.yeah-bubble \{\
 position: absolute;\
 bottom: 52px;\
 left: 50%;\
 transform: translateX(-50%);\
 background: var(--amber);\
 color: #000;\
 font-weight: 800;\
 font-size: 0.78rem;\
 padding: 4px 10px;\
 border-radius: 12px;\
 white-space: nowrap;\
 animation: yeahPop 0.45s cubic-bezier(.22,.68,0,1.2) both;\
 z-index: 3;\
\}\
.yeah-bubble::after \{\
 content: '';\
 position: absolute;\
 bottom: -6px;\
 left: 50%;\
 transform: translateX(-50%);\
 border-left: 6px solid transparent;\
 border-right: 6px solid transparent;\
 border-top: 7px solid var(--amber);\
\}\
@keyframes yeahPop \{\
 from \{ opacity:0; transform: translateX(-50%) scale(0.4); \}\
 to \{ opacity:1; transform: translateX(-50%) scale(1); \}\
\}\
\
/* Finish flag */\
.runner-flag \{\
 position: absolute;\
 right: -4px;\
 bottom: 0;\
 font-size: 1.3rem;\
 line-height: 1;\
 filter: drop-shadow(0 1px 3px rgba(0,0,0,0.4));\
\}\
\
