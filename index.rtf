 '</div>' +\
 '</div>' +\
 '<div class="show-stats">' +\
 '<div>' +\
 '<div class="show-stat-lbl">Avg Listeners</div>' +\
 '<div class="show-stat-val">' + currentAvg + '</div>' +\
 '<div class="show-trend ' + trendClass + '">' + trendSign + trendVal.toFixed(1) + '%</div>' +\
