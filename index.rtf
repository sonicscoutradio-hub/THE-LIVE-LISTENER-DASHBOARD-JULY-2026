\
.wrap \{ position:relative; z-index:2; max-width:1600px; margin:0 auto; padding:22px 28px 40px; \}\
\
/* TOP BAR */\
.topbar \{\
 display:flex; align-items:flex-end; justify-content:space-between;\
 padding-bottom:18px; border-bottom:1px solid var(--amber-dm);\
 margin-bottom:24px; gap:24px; flex-wrap:wrap;\
\}\
.brand \{ display:flex; align-items:center; gap:16px; \}\
.brand-mark \{\
 width:68px; height:68px;\
 display:flex; align-items:center; justify-content:center;\
 flex-shrink:0;\
\}\
.brand-mark img \{ filter:drop-shadow(0 0 8px rgba(232,112,10,.3)); \}\
.frame-lbl \{\
