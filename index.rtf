.platform-info \{\
 flex:1;\
 min-width:0;\
\}\
.platform-lbl \{\
 font-family:'JetBrains Mono',monospace;\
 font-size:8px;\
 letter-spacing:.2em;\
 color:var(--amber);\
 text-transform:uppercase;\
 margin-bottom:2px;\
 font-weight:600;\
\}\
.platform-val \{\
 font-family:'Syne',sans-serif;\
 font-weight:800;\
 font-size:15px;\
 color:var(--amber-br);\
 letter-spacing:-.01em;\
 line-height:1;\
\}\
\
/* BIG Heart button overlay on the Now Playing Artwork panel.\
 Positioned bottom-center of the artwork iframe so users can heart the track they're hearing. */\
.artwork-iframe-wrap \{\
 position:relative;\
 overflow:visible;\
\}\
.artwork-heart-btn \{\
 position:absolute;\
 bottom:14px;\
 left:50%;\
 transform:translateX(-50%);\
 display:flex;\
 align-items:center;\
 gap:8px;\
 padding:8px 14px;\
 background:rgba(0,0,0,.85);\
 border:2px solid var(--amber);\
 border-radius:999px;\
 cursor:pointer;\
 z-index:100;\
 transition:all .2s;\
 backdrop-filter:blur(4px);\
 font-family:'JetBrains Mono',monospace;\
 font-size:10px;\
 letter-spacing:.15em;\
 font-weight:700;\
 color:var(--amber-br);\
 box-shadow:0 4px 14px rgba(0,0,0,.7), 0 0 20px rgba(232,112,10,.3);\
\}\
.artwork-heart-btn:hover \{\
 background:rgba(232,112,10,.22);\
 border-color:var(--amber-br);\
 transform:translateX(-50%) scale(1.05);\
\}\
.artwork-heart-btn:active \{\
 transform:translateX(-50%) scale(0.95);\
\}\
.artwork-heart-icon \{\
 font-size:18px;\
 line-height:1;\
 color:var(--amber);\
 transition:color .15s, transform .15s;\
\}\
.artwork-heart-btn.hearted \{\
 background:rgba(232,112,10,.32);\
 border-color:var(--amber-br);\
\}\
.artwork-heart-btn.hearted .artwork-heart-icon \{\
 color:#ff4060;\
 animation:heartPulse .4s ease;\
\}\
.artwork-heart-btn.hearted .artwork-heart-label \{\
 color:#ff4060;\
\}\
.artwork-heart-btn.disabled \{\
 opacity: 0.35;\
 cursor: not-allowed;\
 filter: grayscale(0.6);\
\}\
.artwork-heart-btn.disabled:hover \{\
 background: rgba(232,112,10,.05);\
 transform: translateX(-50%); /* keep centered, no scale */\
\}\
.artwork-heart-btn.disabled:active \{\
 transform: translateX(-50%); /* don't shrink on click either */\
\}\
\
/* Live Chat section */\
.chat-section \{\
 border-top:1px solid var(--amber-dm);\
 background:rgba(232,112,10,.02);\
\}\
.chat-header \{\
 padding:12px 18px 8px;\
 display:flex; justify-content:space-between; align-items:center;\
 font-family:'JetBrains Mono',monospace;\
 font-size:9px; letter-spacing:.3em;\
 color:var(--amber); text-transform:uppercase;\
\}\
.chat-badge \{\
 display:flex; align-items:center; gap:6px;\
 color:var(--live); font-size:9px;\
 letter-spacing:.2em;\
\}\
.chat-body \{\
 padding:0 14px 14px;\
\}\
.chat-body iframe \{\
 width:100% !important;\
 display:block;\
\}\
\
/* Real world map image */\
.map-image-wrap \{\
 position:absolute;\
 inset:0;\
 background:#0a0806;\
 display:flex;\
 align-items:center;\
 justify-content:center;\
\}\
.d3-map-wrap \{\
 position:absolute;\
 top:0; left:0; right:0; bottom:0;\
 width:100%;\
 height:100%;\
 background:#0a0806;\
 border-radius:4px;\
 overflow:hidden;\
\}\
.d3-map-wrap svg \{\
 display:block;\
 width:100%;\
 height:100%;\
\}\
/* Country paths - navy blue with visible borders */\
.d3-map-wrap .country \{\
 fill:#e8700a; /* Amber landmasses - matches screenshot */\
 stroke:#0a0806; /* Dark borders between countries */\
 stroke-width:0.5;\
 stroke-linejoin:round;\
 vector-effect:non-scaling-stroke;\
 transition:fill .15s;\
\}\
.d3-map-wrap .country:hover \{\
 fill:#ffa030;\
\}\
/* Listener dot markers */\
.d3-map-wrap .listener-dot \{\
 fill:var(--sky);\
 stroke:rgba(255,255,255,.6);\
 stroke-width:0.8;\
 cursor:pointer;\
 filter:drop-shadow(0 0 4px var(--sky));\
 transition:all .15s;\
\}\
.d3-map-wrap .listener-dot.hotspot \{\
 fill:var(--amber-br);\
 filter:drop-shadow(0 0 6px var(--amber-br));\
\}\
.d3-map-wrap .listener-dot:hover \{\
 r:7;\
 stroke-width:1.5;\
\}\
.d3-map-wrap .listener-dot.hotspot:hover \{\
 r:8;\
\}\
/* Custom popup tooltip for dots */\
.d3-map-tooltip \{\
 position:fixed;\
 display:none;\
 background:rgba(10,8,6,.96);\
 border:1px solid var(--amber);\
 padding:10px 14px;\
 font-family:'Syne',sans-serif;\
 border-radius:3px;\
 z-index:9999;\
 pointer-events:none;\
 box-shadow:0 4px 16px rgba(0,0,0,.6), 0 0 24px rgba(232,112,10,.2);\
 min-width:140px;\
\}\
.d3-map-tooltip .tip-city \{\
 font-size:14px;\
 font-weight:700;\
 color:var(--amber-br);\
 margin-bottom:4px;\
\}\
.d3-map-tooltip .tip-variance \{\
 font-family:'JetBrains Mono',monospace;\
 font-size:11px;\
 letter-spacing:.08em;\
 padding-top:5px;\
 margin-top:2px;\
 border-top:1px dashed rgba(232,112,10,.25);\
\}\
.d3-map-tooltip .tip-var-up \{ color:var(--green); \}\
.d3-map-tooltip .tip-var-down \{ color:var(--live); \}\
.map-dots-overlay \{\
 position:absolute;\
 inset:0;\
 width:100%; height:100%;\
 z-index:5;\
 pointer-events:none;\
\}\
.map-dots-overlay .l-dot-group \{\
 pointer-events:auto;\
\}\
\
\
/* Message input in activity panel */\
.activity-input-wrap \{\
 display:flex; gap:6px;\
 padding:8px 18px 10px;\
 border-bottom:1px dashed rgba(232,112,10,.15);\
\}\
.activity-handle \{\
 flex:0 0 110px;\
 min-width:0;\
 background:rgba(232,112,10,.12);\
 border:1px solid var(--amber);\
 color:var(--amber-br);\
 padding:8px 10px;\
 font-family:'JetBrains Mono',monospace;\
 font-size:11px;\
 font-weight:700;\
 letter-spacing:.03em;\
 outline:none;\
 transition:border-color .15s, background .15s;\
\}\
.activity-handle:focus \{\
 border-color:var(--amber-br);\
 background:rgba(232,112,10,.18);\
\}\
.activity-handle::placeholder \{\
 color:rgba(244,160,32,.55);\
 font-weight:500;\
 font-style:italic;\
 letter-spacing:normal;\
\}\
.activity-input \{\
 flex:1;\
 min-width:0;\
 background:rgba(232,112,10,.12);\
 border:1px solid var(--amber);\
 color:var(--amber-br);\
 padding:8px 12px;\
 font-family:'Syne',sans-serif;\
 font-size:12px;\
 font-weight:600;\
 outline:none;\
 transition:border-color .15s, background .15s;\
\}\
.activity-input:focus \{\
 border-color:var(--amber-br);\
 background:rgba(232,112,10,.18);\
\}\
.activity-input::placeholder \{\
 color:rgba(244,160,32,.55);\
 font-weight:400;\
 font-style:italic;\
\}\
.activity-input:disabled,\
.activity-handle:disabled \{\
 opacity:.4;\
 cursor:not-allowed;\
\}\
.activity-send \{\
 background:var(--amber);\
 color:#fff;\
 border:none;\
 padding:0 14px;\
 font-family:'JetBrains Mono',monospace;\
 font-size:14px;\
 font-weight:700;\
 cursor:pointer;\
 transition:background .15s, opacity .15s;\
\}\
.activity-send:hover \{ background:var(--amber-br); \}\
.activity-send:active \{ transform:scale(.95); \}\
.activity-send:disabled \{\
 background:var(--amber-dm);\
 cursor:not-allowed;\
 opacity:.5;\
\}\
/* User-sent messages get a distinct style */\
.activity-item.user-msg \{\
 background:rgba(232,112,10,.08);\
 border-left:3px solid var(--amber-br);\
\}\
\
/* Interactive listener dot tooltip */\
.l-dot-group \{ cursor:pointer; \}\
.l-dot-group .l-dot \{\
 transition:r .15s, filter .15s;\
\}\
.l-dot-group:hover .l-dot \{\
 r:6;\
 filter:drop-shadow(0 0 8px var(--sky)) brightness(1.3);\
\}\
.l-dot-group:hover .l-dot.big \{\
 filter:drop-shadow(0 0 10px var(--amber-br)) brightness(1.3);\
\}\
.map-tooltip \{\
 position:fixed;\
 display:none;\
 background:rgba(10,8,6,.95);\
 border:1px solid var(--amber);\
 padding:8px 14px;\
 font-family:'Syne',sans-serif;\
 z-index:9999;\
 pointer-events:none;\
 box-shadow:0 4px 16px rgba(0,0,0,.6), 0 0 20px rgba(232,112,10,.15);\
 min-width:120px;\
\}\
.map-tooltip .tip-city \{\
 font-size:14px;\
 font-weight:700;\
 color:var(--amber-br);\
 letter-spacing:-.01em;\
 margin-bottom:4px;\
\}\
.map-tooltip .tip-variance \{\
 font-family:'JetBrains Mono',monospace;\
 font-size:11px;\
 font-weight:600;\
 letter-spacing:.08em;\
 padding-top:4px;\
 border-top:1px dashed rgba(232,112,10,.2);\
\}\
.map-tooltip .tip-var-up \{ color:var(--green); \}\
.map-tooltip .tip-var-down \{ color:var(--live); \}\
\
\
/* Custom Live Chat */\
.chat-body-custom \{\
 padding:8px 14px 12px;\
 display:flex;\
 flex-direction:column;\
 gap:6px;\
\}\
.chat-messages \{\
 height:280px;\
 overflow-y:auto;\
 display:flex;\
 flex-direction:column-reverse;\
 gap:6px;\
 padding:8px;\
 background:rgba(0,0,0,.25);\
 border:1px solid var(--amber-dm);\
 border-radius:4px;\
 scrollbar-width:thin;\
 scrollbar-color:var(--amber-dm) transparent;\
\}\
.chat-messages::-webkit-scrollbar \{ width:6px; \}\
.chat-messages::-webkit-scrollbar-track \{ background:transparent; \}\
.chat-messages::-webkit-scrollbar-thumb \{ background:var(--amber-dm); border-radius:3px; \}\
.chat-msg \{\
 padding:6px 10px;\
 font-size:12px;\
 line-height:1.4;\
 border-left:2px solid var(--amber-dm);\
 background:rgba(232,112,10,.03);\
 animation:chat-slide-in .3s ease;\
\}\
@keyframes chat-slide-in \{\
 from \{ transform:translateX(-6px); opacity:0; \}\
 to \{ transform:translateX(0); opacity:1; \}\
\}\
.chat-msg.user-msg \{\
 border-left-color:var(--amber-br);\
 background:rgba(232,112,10,.1);\
\}\
.chat-msg-name \{\
 color:var(--amber-br);\
 font-weight:700;\
 font-family:'Syne',sans-serif;\
 margin-right:6px;\
\}\
.chat-msg-time \{\
 font-family:'JetBrains Mono',monospace;\
 font-size:9px;\
 color:var(--text);\
 letter-spacing:.1em;\
 float:right;\
 opacity:.6;\
\}\
.chat-msg-text \{\
 color:var(--text);\
 word-wrap:break-word;\
\}\
.chat-input-wrap \{\
 display:flex;\
 gap:6px;\
\}\
.chat-input \{\
 flex:1;\
 background:rgba(0,0,0,.3);\
 border:1px solid var(--amber-dm);\
 color:var(--text);\
 padding:8px 12px;\
 font-family:'Syne',sans-serif;\
 font-size:12px;\
 outline:none;\
 border-radius:3px;\
 transition:border-color .15s;\
\}\
.chat-input:focus \{\
 border-color:var(--amber);\
 background:rgba(0,0,0,.5);\
\}\
.chat-input::placeholder \{\
 color:var(--text);\
 opacity:.5;\
 font-style:italic;\
\}\
.chat-send \{\
 background:var(--amber);\
 color:#fff;\
 border:none;\
 padding:0 14px;\
 font-family:'JetBrains Mono',monospace;\
 font-size:14px;\
 font-weight:700;\
 cursor:pointer;\
 border-radius:3px;\
 transition:background .15s;\
\}\
.chat-send:hover \{ background:var(--amber-br); \}\
.chat-send:active \{ transform:scale(.95); \}\
\
/* Presenter Login & Reply UI */\
.presenter-panel-inline \{\
 padding:12px 14px 14px;\
 display:flex;\
 justify-content:center;\
 border-top:1px dashed rgba(232,112,10,.2);\
 margin-top:8px;\
\}\
.presenter-lock-btn \{\
 background:transparent;\
 border:1px solid var(--amber-dm);\
 color:var(--text);\
 padding:8px 16px;\
 font-family:'JetBrains Mono',monospace;\
 font-size:10px;\
 font-weight:600;\
 letter-spacing:.2em;\
 text-transform:uppercase;\
 cursor:pointer;\
 border-radius:3px;\
 transition:all .2s;\
 display:flex; align-items:center; gap:8px;\
\}\
.presenter-lock-btn:hover \{\
 border-color:var(--amber);\
 color:var(--amber-br);\
 background:rgba(232,112,10,.08);\
\}\
.presenter-lock-btn:hover \{\
 border-color:var(--amber);\
 background:rgba(232,112,10,.1);\
 color:var(--amber-br);\
\}\
.lock-icon \{ font-size:12px; \}\
\
.presenter-badge \{\
 background:rgba(62,207,142,.12);\
 border:1px solid var(--green);\
 padding:8px 14px;\
 font-family:'JetBrains Mono',monospace;\
 font-size:10px;\
 letter-spacing:.15em;\
 border-radius:3px;\
 display:flex; align-items:center; gap:10px;\
 color:var(--text);\
\}\
.presenter-badge strong \{ color:var(--green); \}\
.presenter-badge-dot \{\
 width:8px; height:8px;\
 background:var(--green);\
 border-radius:50%;\
 animation:pulse-green 2s ease infinite;\
\}\
.presenter-logout-btn \{\
 background:transparent;\
 border:1px solid var(--text-mute);\
 color:var(--text);\
 padding:3px 10px;\
 font-family:'JetBrains Mono',monospace;\
 font-size:9px;\
 letter-spacing:.2em;\
 cursor:pointer;\
 border-radius:2px;\
 margin-left:6px;\
\}\
.presenter-logout-btn:hover \{\
 border-color:var(--live);\
 color:var(--live);\
\}\
\
/* MODAL */\
.presenter-modal \{\
 position:fixed;\
 inset:0;\
 background:rgba(0,0,0,.7);\
 z-index:1000;\
 display:flex;\
 align-items:center;\
 justify-content:center;\
 backdrop-filter:blur(4px);\
\}\
.presenter-modal-box \{\
 background:var(--bg-card);\
 border:2px solid var(--amber);\
 padding:28px;\
 width:90%;\
 max-width:440px;\
 box-shadow:0 0 40px rgba(232,112,10,.3);\
 border-radius:4px;\
\}\
.presenter-modal-title \{\
 font-family:'Syne',sans-serif;\
 font-size:22px; font-weight:800;\
 color:var(--amber-br);\
 margin-bottom:4px;\
\}\
.presenter-modal-sub \{\
 font-family:'JetBrains Mono',monospace;\
 font-size:10px;\
 letter-spacing:.2em;\
 color:var(--text);\
 text-transform:uppercase;\
 margin-bottom:22px;\
 padding-bottom:14px;\
 border-bottom:1px dashed var(--amber-dm);\
\}\
.presenter-field \{\
 display:block;\
 margin-bottom:16px;\
\}\
.presenter-field > span \{\
 display:block;\
 font-family:'JetBrains Mono',monospace;\
 font-size:9px;\
 letter-spacing:.25em;\
 color:var(--amber);\
 text-transform:uppercase;\
 margin-bottom:6px;\
\}\
.presenter-field input,\
.presenter-field select,\
.presenter-field textarea \{\
 width:100%;\
 background:rgba(0,0,0,.3);\
 border:1px solid var(--amber-dm);\
 color:var(--text);\
 padding:10px 12px;\
 font-family:'Syne',sans-serif;\
 font-size:14px;\
 outline:none;\
 border-radius:3px;\
 transition:border-color .15s;\
 resize:vertical;\
\}\
.presenter-field input:focus,\
.presenter-field select:focus,\
.presenter-field textarea:focus \{\
 border-color:var(--amber);\
 background:rgba(0,0,0,.5);\
\}\
.presenter-field select option \{\
 background:var(--bg-card);\
 color:var(--text);\
\}\
.presenter-err \{\
 color:var(--live);\
 font-family:'JetBrains Mono',monospace;\
 font-size:11px;\
 letter-spacing:.1em;\
 margin-bottom:12px;\
 min-height:16px;\
\}\
.presenter-modal-buttons \{\
 display:flex;\
 gap:10px;\
 justify-content:flex-end;\
\}\
.presenter-btn-cancel,\
.presenter-btn-ok \{\
 padding:10px 20px;\
 font-family:'JetBrains Mono',monospace;\
 font-size:10px;\
 font-weight:700;\
 letter-spacing:.2em;\
 text-transform:uppercase;\
 cursor:pointer;\
 border:none;\
 border-radius:3px;\
\}\
.presenter-btn-cancel \{\
 background:transparent;\
 border:1px solid var(--text-mute);\
 color:var(--text);\
\}\
.presenter-btn-cancel:hover \{ border-color:var(--text); \}\
.presenter-btn-ok \{\
 background:var(--amber);\
 color:#fff;\
\}\
.presenter-btn-ok:hover \{ background:var(--amber-br); \}\
\
/* Reply button next to chat messages */\
.activity-reply-btn \{\
 display:none;\
 background:rgba(232,112,10,.2);\
 border:1px solid var(--amber);\
 color:var(--amber-br);\
 padding:2px 8px;\
 font-family:'JetBrains Mono',monospace;\
 font-size:9px;\
 font-weight:700;\
 letter-spacing:.15em;\
 cursor:pointer;\
 border-radius:2px;\
 margin-left:6px;\
 text-transform:uppercase;\
\}\
.activity-reply-btn:hover \{\
 background:var(--amber);\
 color:#fff;\
\}\
/* When logged in, show reply buttons */\
body.presenter-mode .activity-reply-btn \{ display:inline-block; \}\
\
/* Presenter reply item in feed (distinctive styling) */\
.activity-item.presenter-reply \{\
 background:linear-gradient(90deg, rgba(232,112,10,.18), rgba(232,112,10,.05));\
 border-left:3px solid var(--amber-br);\
 padding-left:14px;\
 margin-left:16px;\
 position:relative;\
\}\
.activity-item.presenter-reply::before \{\
 content:'';\
 position:absolute;\
 left:0;\
 top:0;\
 bottom:50%;\
 width:14px;\
 border-left:1px solid var(--amber-dm);\
 border-bottom:1px solid var(--amber-dm);\
 border-bottom-left-radius:6px;\
 pointer-events:none;\
\}\
.activity-item.presenter-reply .activity-icon \{\
 background:var(--amber);\
 color:#fff;\
 font-weight:700;\
\}\
.activity-item.presenter-reply .presenter-name \{\
 color:var(--amber-br);\
 font-weight:700;\
 text-transform:none;\
 letter-spacing:0;\
 font-family:'Syne',sans-serif;\
 font-size:12px;\
\}\
.activity-item.presenter-reply .reply-arrow \{\
 color:var(--text-mute);\
 margin:0 2px;\
 font-size:11px;\
\}\
.activity-item.presenter-reply .reply-to \{\
 color:var(--text);\
 font-weight:600;\
 font-size:11px;\
\}\
.activity-item.user-reply-back \{\
 margin-left:32px;\
 border-left:2px solid rgba(232,112,10,.25);\
 padding-left:10px;\
 position:relative;\
\}\
.activity-item.user-reply-back::before \{\
 content:'';\
 position:absolute;\
 left:-1px;\
 top:-6px;\
 width:12px;\
 height:50%;\
 border-left:1px solid var(--amber-dm);\
 border-bottom:1px solid var(--amber-dm);\
 border-bottom-left-radius:4px;\
 pointer-events:none;\
 opacity:0.5;\
\}\
.presenter-label \{\
 display:inline-block;\
 background:var(--amber);\
 color:#fff;\
 padding:1px 6px;\
 font-family:'JetBrains Mono',monospace;\
 font-size:8px;\
 letter-spacing:.2em;\
 font-weight:700;\
 border-radius:2px;\
 margin-right:6px;\
 vertical-align:middle;\
\}\
\
/* */\
/* MOBILE RESPONSIVE OVERRIDES (768px) */\
/* These rules only activate on small screens. Desktop is untouched. */\
/* */\
@media (max-width: 768px) \{\
\
 /* Topbar: stack brand + status vertically with breathing room */\
 .topbar \{\
 flex-direction: column;\
 align-items: flex-start;\
 gap: 14px;\
 padding-bottom: 14px;\
 margin-bottom: 18px;\
 \}\
 .brand \{ gap: 12px; \}\
 .brand-mark \{ width: 52px; height: 52px; \}\
 .brand-mark img \{ max-width: 52px; height: auto; \}\
 .brand-text h1 \{ font-size: 20px; line-height: 1.1; \}\
\
 /* Status cluster: wrap to multiple lines instead of squashing */\
 .status-cluster \{\
 width: 100%;\
 flex-wrap: wrap;\
 gap: 12px 18px;\
 align-items: flex-start;\
 \}\
 .status-item \{\
 padding-left: 10px;\
 border-left: 1px solid var(--amber-dm);\
 flex: 0 1 auto;\
 \}\
 .status-item:first-child \{ padding-left: 0; border-left: none; \}\
 .status-val \{ font-size: 12px; gap: 6px; \}\
 .status-lbl \{ font-size: 8px; \}\
 .refresh-badge \{ font-size: 9px; padding: 1px 6px; \}\
\
 /* Stats strip: hero spans full width, others 2-up */\
 .stats-strip \{\
 grid-template-columns: 1fr 1fr;\
 gap: 6px;\
 \}\
 .stat.hero \{ grid-column: 1 / -1; \}\
 .stat \{ padding: 12px 12px; \}\
 .stat-big \{ font-size: 24px; \}\
 .stat.hero .stat-big \{ font-size: 32px; \}\
 .stat-big .unit \{ font-size: 10px; \}\
 .stat-trend \{ font-size: 10px; \}\
 .stat-lbl \{ font-size: 8px; letter-spacing: .15em; margin-bottom: 6px; \}\
\
 /* Main grid stacks (was already 1100px, but reinforce for smaller) */\
 .main-grid \{ grid-template-columns: 1fr; gap: 16px; margin-bottom: 18px; \}\
\
 /* Side stack spacing tighter on mobile */\
 .side-stack \{ gap: 16px; \}\
\
 /* Map panel: shorter on mobile so it doesn't dominate the screen */\
 .map-wrap \{ height: 360px; \}\
 .d3-map-wrap \{ min-height: 320px; \}\
 .map-legend \{\
 position: static;\
 margin: 8px 12px 12px;\
 flex-wrap: wrap;\
 font-size: 9px;\
 gap: 10px;\
 \}\
\
 /* Panel headers: keep title and meta on same row but allow wrap */\
 .panel-header \{\
 flex-wrap: wrap;\
 gap: 6px;\
 padding: 12px 14px;\
 \}\
 .panel-title \{ font-size: 11px; letter-spacing: .2em; \}\
 .panel-meta \{ font-size: 10px; \}\
\
 /* Section titles: smaller and tighter */\
 .section-title \{ font-size: 18px; gap: 10px; \}\
 .section-title::before \{ height: 18px; \}\
 .section-sub \{ font-size: 9px; letter-spacing: .18em; \}\
\
 /* Show grid: 1 column on phone (auto-fill 280px would otherwise force 1 anyway, but explicit) */\
 .shows-grid \{ grid-template-columns: 1fr; gap: 12px; \}\
\
 /* Editorial grid stack */\
 .editorial-grid \{\
 grid-template-columns: 1fr;\
 padding: 0 12px;\
 margin: 18px 0;\
 gap: 14px;\
 \}\
\
 /* Command center panels stack */\
 .cc-panels \{ grid-template-columns: 1fr; \}\
 .cc-panel \{ min-height: auto; padding: 14px 14px; \}\
\
 /* Info grid (Schedule | Top Tracks | Subscriptions) stacks */\
 .info-grid \{\
 grid-template-columns: 1fr;\
 gap: 12px;\
 margin-top: 18px;\
 \}\
 .info-panel \{ min-height: auto; \}\
\
 /* Platform streams (iOS / Android / Web): keep 3-up but allow shrink */\
 .platform-streams \{ gap: 4px; \}\
\
 /* Wrap padding */\
 .wrap \{ padding: 14px 12px 32px; \}\
\
 /* FIX: Prevent any element from forcing horizontal overflow */\
 /* This is the root cause of content appearing clipped at the right edge:\
 when something inside is wider than the viewport, even body overflow-x:hidden\
 can leave child content shifted. Constrain everything to 100% on mobile. */\
 .panel, .cc-panel, .ed-panel, .info-panel, .stat,\
 .on-air-wrap, .vibe-section, .vibe-globe-wrap-full \{\
 max-width: 100%;\
 overflow-wrap: break-word;\
 word-wrap: break-word;\
 \}\
 /* Hard constraint on top-level containers  nothing inside can blow them out.\
 overflow-x: hidden is safe on .panel and .cc-panel because they don't have\
 fixed heights  vertical scroll happens on the page level (body), and\
 specific scrollable children (.activity-feed, .cc-countries-list, etc.)\
 manage their own internal scroll via overflow-y. */\
 .wrap \{\
 max-width: 100vw;\
 overflow-x: hidden;\
 \}\
 .main-grid, .side-stack \{\
 max-width: 100%;\
 \}\
 .panel, .cc-panel, .ed-panel, .info-panel, .nowplaying-panel,\
 .on-air-wrap, .vibe-section \{\
 max-width: 100%;\
 overflow-x: hidden;\
 /* DO NOT set overflow-y here  let page scrolling work normally */\
 \}\
\
 /* FIX: section-header (e.g. "All Shows This Week" + date range) \
 was a flex row with space-between, which on mobile squished the title\
 into 3 lines and pushed the date column off-screen. Stack vertically. */\
 .section-header \{\
 flex-direction: column;\
 align-items: flex-start;\
 gap: 6px;\
 margin-bottom: 12px;\
 \}\
 .section-sub \{\
 letter-spacing: .15em;\
 word-break: break-word;\
 overflow-wrap: break-word;\
 max-width: 100%;\
 \}\
\
 /* FIX: high letter-spacing labels overflowing the viewport \
 Reduce letter-spacing on mobile for any all-caps tracking text that\
 can exceed the screen width (e.g. "GLOBAL LIVE LISTENER COMMAND\
 CENTER", "LIVE LISTENER ACTIVITY", "TOP 10 COUNTRIES  LIVE"). */\
 .cc-panel-eyebrow,\
 .activity-divider,\
 .panel-title,\
 .ed-eyebrow,\
 .info-panel-eyebrow \{\
 letter-spacing: 0.12em !important;\
 word-break: break-word;\
 overflow-wrap: break-word;\
 white-space: normal;\
 max-width: 100%;\
 \}\
\
 /* Now Playing track title can be very long  ensure ellipsis works\
 by giving it a definite max-width relative to its container. */\
 .np-track-title, .np-track-artist \{\
 max-width: 100%;\
 min-width: 0;\
 \}\
 .np-track-display \{ min-width: 0; max-width: 100%; \}\
\
 /* FIX: Activity input wrap  handle (110px fixed) + input + send\
 button could push past viewport on narrow screens. Make handle\
 narrower and ensure the row itself can shrink. */\
 .activity-input-wrap \{\
 flex-wrap: wrap;\
 padding: 8px 12px 10px;\
 max-width: 100%;\
 min-width: 0;\
 \}\
 .activity-handle \{\
 flex: 0 0 90px;\
 font-size: 10px;\
 padding: 8px;\
 \}\
 .activity-input \{\
 flex: 1 1 auto;\
 min-width: 100px;\
 \}\
 .activity-send \{\
 flex-shrink: 0;\
 \}\
\
 /* FIX: Top 10 Countries  percentage column was being pushed\
 off-screen because the bar (1fr) didn't have min-width:0, so on\
 narrow screens the row couldn't shrink properly. */\
 .cc-countries-list \{ max-width: 100%; min-width: 0; \}\
 .cc-country-row \{\
 max-width: 100%;\
 min-width: 0;\
 grid-template-columns: 22px minmax(0, 1fr) auto;\
 gap: 8px;\
 \}\
 .cc-country-name-wrap \{ min-width: 0; max-width: 100%; \}\
 .cc-country-name \{ font-size: 11px; \}\
 .cc-country-pct \{ font-size: 11px; \}\
\
 /* FIX: Vibe section / map panel containers were overflowing */\
 .vibe-section, .vibe-globe-wrap-full, .vibe-globe-legend \{\
 max-width: 100%;\
 overflow-x: hidden;\
 min-width: 0;\
 \}\
\
 /* FIX: Stat blocks  if a number is large (e.g. "1,234") with\
 white-space:nowrap, the stat tile can blow out the row. */\
 .stat \{ min-width: 0; max-width: 100%; \}\
 .stat-big \{\
 overflow-wrap: break-word;\
 word-break: break-word;\
 \}\
\
 /* Final safety net: ALL direct children of major flex/grid containers\
 get min-width:0 so they're allowed to shrink below their content's\
 intrinsic size on mobile. Without this, flex/grid children default\
 to min-width:auto which is the most common cause of mobile overflow. */\
 .main-grid > *,\
 .side-stack > *,\
 .stats-strip > *,\
 .cc-panels > *,\
 .info-grid > *,\
 .editorial-grid > *,\
 .platform-streams > *,\
 .shows-grid > * \{\
 min-width: 0;\
 max-width: 100%;\
 \}\
 /* Activity feed messages can contain long handles/URLs that push width */\
 .activity-feed, .activity-item, .activity-text \{\
 max-width: 100%;\
 overflow-wrap: break-word;\
 word-break: break-word;\
 min-width: 0;\
 \}\
 /* Iframes that say width=100% can still push parent if their internal min-content is wide */\
 .panel iframe, .nowplaying-body iframe, .player-body iframe \{\
 max-width: 100%;\
 \}\
 /* Ensure all text content inside panels wraps properly */\
 .cc-welcome-body, .cc-welcome-body p, .ed-blurb, .ed-hero-line \{\
 overflow-wrap: break-word;\
 word-wrap: break-word;\
 hyphens: auto;\
 max-width: 100%;\
 \}\
 .cc-panel-body, .ed-panel-body, .cc-welcome-body \{ min-width: 0; \}\
 /* The cc-panels grid itself must allow shrinking */\
 .cc-panels \{ min-width: 0; max-width: 100%; \}\
 .cc-panel \{ min-width: 0; max-width: 100%; \}\
\
 /* FIX: vibeGlobe SVG was forcing parent wider than viewport */\
 /* Make height auto-scale so the SVG can shrink to fit narrow screens\
 (was fixed at 460px, which combined with viewBox aspect ratio caused\
 the rendered width to extend past mobile viewports). */\
 #vibeGlobe \{\
 width: 100%;\
 height: auto;\
 max-width: 100%;\
 aspect-ratio: 600 / 460;\
 \}\
 .vibe-section \{ padding: 8px; \}\
 .vibe-globe-wrap-full \{ padding: 4px; \}\
\
 /* FIX: On Air Now show title was overflowing the column */\
 /* "Outcast Frequency" was being clipped because 26px Syne with negative\
 letter-spacing exceeds the narrow column width. Allow it to wrap and\
 reduce size. */\
 .on-air-show \{\
 font-size: 22px;\
 line-height: 1.15;\
 word-break: break-word;\
 overflow-wrap: break-word;\
 hyphens: auto;\
 \}\
 .on-air-host \{ font-size: 12px; letter-spacing: .08em; \}\
 .on-air-body \{ padding: 14px 14px; gap: 12px; \}\
 /* Smaller image on mobile so the rest of the block (LIVE badge, host,\
 waveform, listener counts) is visible without excessive scrolling */\
 .on-air-art \{ width: 100%; height: 160px; max-height: 35vh; \}\
 .on-air-art img \{ object-fit: cover; object-position: center top; \}\
 .on-air-info \{ width: 100%; min-width: 0; \}\
 .oa-stat-val \{ font-size: 19px; \}\
 .oa-stat-val.small \{ font-size: 14px; \}\
 .oa-stat-lbl \{ font-size: 8px; letter-spacing: .18em; \}\
\
 /* FIX: Editorial / cc-welcome panel padding tighter on mobile */\
 .ed-panel-body \{ padding: 16px 16px; \}\
 .cc-panel \{ padding: 14px 14px; min-width: 0; \}\
 .cc-welcome-body \{ font-size: 12px; \}\
 .cc-welcome-headline \{ font-size: 13px !important; \}\
\
 /* Brand text shouldn't overflow either */\
 .brand-text \{ min-width: 0; flex: 1; \}\
 .brand-text h1 \{ word-break: break-word; \}\
\}\
\
/* EXTRA SMALL (480px) */\
@media (max-width: 480px) \{\
\
 .wrap \{ padding: 12px 8px 28px; \}\
\
 /* Brand a bit smaller still */\
 .brand-mark \{ width: 44px; height: 44px; \}\
 .brand-mark img \{ max-width: 44px; \}\
 .brand-text h1 \{ font-size: 17px; \}\
 .frame-lbl \{ font-size: 8px; letter-spacing: .25em; \}\
\
 /* Status cluster: more compact */\
 .status-cluster \{ gap: 10px 14px; \}\
 .status-val \{ font-size: 11px; \}\
\
 /* Stats: tighter still */\
 .stats-strip \{ gap: 4px; \}\
 .stat \{ padding: 10px 10px; \}\
 .stat-big \{ font-size: 21px; \}\
 .stat.hero .stat-big \{ font-size: 28px; \}\
\
 /* Map a touch shorter */\
 .map-wrap \{ height: 320px; \}\
 .d3-map-wrap \{ min-height: 280px; \}\
\
 /* Section titles tighter */\
 .section-title \{ font-size: 16px; \}\
\
 /* Platform streams: stack on very small screens to avoid cramped 3-col */\
 .platform-streams \{ grid-template-columns: 1fr; gap: 4px; \}\
\
 /* On Air title smaller still on tiny screens */\
 .on-air-show \{ font-size: 20px; \}\
 .on-air-art \{ height: 140px; max-height: 30vh; \}\
\
 /* Welcome panel headline tighter */\
 .cc-welcome-headline \{ font-size: 12px !important; \}\
 .cc-welcome-body \{ font-size: 11px; line-height: 1.6; \}\
\}\
\
\
/* ===== LISTENERS JOINING FEED ===== */\
.joining-feed \{\
 display: flex;\
 flex-direction: column;\
 gap: 0;\
 max-height: 340px;\
 overflow: hidden;\
 position: relative;\
\}\
.joining-row \{\
 display: flex;\
 align-items: center;\
 gap: 10px;\
 padding: 7px 12px;\
 border-bottom: 1px solid rgba(232,112,10,0.08);\
 animation: joinSlideIn 0.45s cubic-bezier(.22,.68,0,1.2) both;\
 background: transparent;\
 transition: background 0.3s;\
\}\
.joining-row:first-child \{\
 background: rgba(232,112,10,0.06);\
\}\
@keyframes joinSlideIn \{\
 from \{ opacity: 0; transform: translateY(-14px); \}\
 to \{ opacity: 1; transform: translateY(0); \}\
\}\
.joining-flag \{\
 width: 24px;\
 min-width: 24px;\
 line-height: 1;\
 flex-shrink: 0;\
 display: inline-flex;\
 align-items: center;\
 justify-content: center;\
\}\
.joining-flag img \{\
 width: 22px;\
 height: 16px;\
 object-fit: cover;\
 border-radius: 2px;\
 box-shadow: 0 1px 2px rgba(0,0,0,0.4);\
 display: block;\
\}\
.joining-info \{\
 flex: 1;\
 min-width: 0;\
\}\
.joining-location \{\
 font-size: 0.82rem;\
 font-weight: 600;\
 color: var(--text-primary);\
 white-space: nowrap;\
 overflow: hidden;\
 text-overflow: ellipsis;\
\}\
.joining-sub \{\
 font-size: 0.72rem;\
 color: var(--text-muted);\
 margin-top: 1px;\
\}\
.joining-dot \{\
 width: 7px;\
 height: 7px;\
 border-radius: 50%;\
 background: #22c55e;\
 flex-shrink: 0;\
 box-shadow: 0 0 6px rgba(34,197,94,0.7);\
 animation: joinPulse 2s ease-in-out infinite;\
\}\
@keyframes joinPulse \{\
 0%, 100% \{ opacity: 1; \}\
 50% \{ opacity: 0.4; \}\
\}\
.joining-count-bar \{\
 display: flex;\
 align-items: center;\
 justify-content: space-between;\
 padding: 6px 12px 8px;\
 font-size: 0.72rem;\
 color: var(--text-muted);\
 border-bottom: 1px solid rgba(232,112,10,0.12);\
 margin-bottom: 2px;\
\}\
.joining-count-bar strong \{\
 color: var(--amber);\
\}\
\
\
/* ===== SOCIAL MEDIA STRIP ===== */\
.social-strip \{\
 display: flex;\
 align-items: center;\
 justify-content: center;\
 gap: 14px;\
 padding: 10px 24px;\
 background: rgba(232,112,10,0.05);\
 border-bottom: 1px solid rgba(232,112,10,0.15);\
 flex-wrap: wrap;\
\}\
.social-strip-label \{\
 font-size: 0.68rem;\
 letter-spacing: 0.15em;\
 text-transform: uppercase;\
 color: var(--text-muted);\
 margin-right: 4px;\
\}\
.social-btn \{\
 display: flex;\
 align-items: center;\
 gap: 7px;\
 padding: 6px 14px;\
 border-radius: 20px;\
 border: 1px solid rgba(232,112,10,0.25);\
 background: rgba(232,112,10,0.06);\
 color: var(--text-primary);\
 text-decoration: none;\
 font-size: 0.78rem;\
 font-weight: 600;\
 transition: background 0.2s, border-color 0.2s, transform 0.15s;\
 white-space: nowrap;\
\}\
.social-btn:hover \{\
 background: rgba(232,112,10,0.18);\
 border-color: var(--amber);\
 transform: translateY(-1px);\
 color: var(--amber);\
\}\
.social-btn svg \{ flex-shrink: 0; \}\
\
/* ===== MILESTONE BAR ===== */\
.milestone-bar-wrap \{\
 padding: 14px 28px 10px;\
 background: rgba(232,112,10,0.03);\
 border-bottom: 1px solid rgba(232,112,10,0.12);\
\}\
.milestone-bar-header \{\
 display: flex;\
 align-items: center;\
 justify-content: space-between;\
 margin-bottom: 7px;\
\}\
.milestone-bar-label \{\
 font-size: 0.72rem;\
 letter-spacing: 0.12em;\
 text-transform: uppercase;\
 color: var(--text-muted);\
\}\
.milestone-bar-count \{\
 font-size: 0.78rem;\
 font-weight: 700;\
 color: var(--amber);\
\}\
.milestone-track \{\
 height: 8px;\
 background: rgba(255,255,255,0.07);\
 border-radius: 4px;\
 overflow: hidden;\
 border: 1px solid rgba(232,112,10,0.15);\
\}\
.milestone-fill \{\
 height: 100%;\
 background: linear-gradient(90deg, #e8700a, #ffaa44);\
 border-radius: 4px;\
 transition: width 1.2s cubic-bezier(.22,.68,0,1.2);\
 position: relative;\
 min-width: 4px;\
\}\
.milestone-fill::after \{\
 content: '';\
 position: absolute;\
 right: 0; top: 0; bottom: 0;\
 width: 14px;\
 background: rgba(255,255,255,0.35);\
 border-radius: 4px;\
 animation: mileSpark 1.8s ease-in-out infinite;\
\}\
@keyframes mileSpark \{\
 0%,100% \{ opacity:0.3; \}\
 50% \{ opacity:1; \}\
\}\
.milestone-bar-sub \{\
 margin-top: 5px;\
 font-size: 0.68rem;\
 color: var(--text-muted);\
 text-align: right;\
\}\
@media(max-width:600px)\{\
 .milestone-bar-wrap \{ padding:12px 14px 8px; \}\
\}\
\
/* ===== LIVE COVER ART PANEL ===== */\
.coverart-panel \{\
 background: rgba(232,112,10,0.04);\
 border: 1px solid rgba(232,112,10,0.18);\
 border-radius: 10px;\
 overflow: hidden;\
 margin-top: 12px;\
\}\
.coverart-inner \{\
 display: flex;\
 align-items: center;\
 gap: 14px;\
 padding: 14px;\
\}\
.coverart-img-wrap \{\
 position: relative;\
 flex-shrink: 0;\
\}\
.coverart-img \{\
 width: 80px;\
 height: 80px;\
 border-radius: 8px;\
 object-fit: cover;\
 background: #1a1a1a;\
 display: block;\
 border: 1px solid rgba(232,112,10,0.2);\
\}\
.coverart-vinyl \{\
 position: absolute;\
 right: -18px; top: 50%;\
 transform: translateY(-50%);\
 width: 56px; height: 56px;\
 border-radius: 50%;\
 background: radial-gradient(circle at 50% 50%, #111 28%, #222 30%, #1a1a1a 50%, #111 52%);\
 border: 1px solid rgba(255,255,255,0.08);\
 animation: vinylSpin 4s linear infinite;\
 z-index: 0;\
\}\
@keyframes vinylSpin \{ to \{ transform: translateY(-50%) rotate(360deg); \} \}\
.coverart-info \{\
 flex: 1;\
 min-width: 0;\
 margin-left: 22px;\
\}\
.coverart-now \{\
 font-size: 0.65rem;\
 letter-spacing: 0.14em;\
 text-transform: uppercase;\
 color: var(--amber);\
 margin-bottom: 3px;\
\}\
.coverart-track \{\
 font-size: 0.95rem;\
 font-weight: 700;\
 color: var(--text-primary);\
 white-space: nowrap;\
 overflow: hidden;\
 text-overflow: ellipsis;\
\}\
.coverart-artist \{\
 font-size: 0.8rem;\
 color: var(--text-muted);\
 margin-top: 2px;\
 white-space: nowrap;\
 overflow: hidden;\
 text-overflow: ellipsis;\
\}\
.coverart-placeholder \{\
 font-size: 0.78rem;\
 color: var(--text-muted);\
 font-style: italic;\
\}\
\
/* ===== QR CODE PANEL ===== */\
.qr-panel \{\
 margin-top: 18px;\
 padding: 16px;\
 background: rgba(232,112,10,0.04);\
 border: 1px solid rgba(232,112,10,0.18);\
 border-radius: 10px;\
\}\
.qr-panel-title \{\
 font-size: 0.7rem;\
 letter-spacing: 0.15em;\
 text-transform: uppercase;\
 color: var(--amber);\
 margin-bottom: 12px;\
 text-align: center;\
\}\
.qr-codes \{\
 display: flex;\
 gap: 18px;\
 justify-content: center;\
 flex-wrap: wrap;\
\}\
.qr-code-item \{\
 display: flex;\
 flex-direction: column;\
 align-items: center;\
 gap: 8px;\
 text-decoration: none;\
\}\
.qr-code-item img \{\
 width: 110px;\
 height: 110px;\
 border-radius: 8px;\
 background: #fff;\
 padding: 6px;\
 display: block;\
 border: 1px solid rgba(232,112,10,0.2);\
\}\
.qr-code-label \{\
 font-size: 0.7rem;\
 color: var(--text-muted);\
 text-align: center;\
 font-weight: 600;\
\}\
.qr-code-item:hover .qr-code-label \{ color: var(--amber); \}\
