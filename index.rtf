// REPLY BUTTON INJECTION \
// Patches addActivityItem so each listener-typed message (chat type) gets a reply button\
var _origAddActivityItem = typeof addActivityItem === 'function' ? addActivityItem : null;\
if (_origAddActivityItem) \{\
 addActivityItem = function() \{\
 _origAddActivityItem.apply(this, arguments);\
 attachReplyButtons();\
 \};\
\}\
\
function attachReplyButtons() \{\
 var feed = document.getElementById('activityFeed');\
 if (!feed) return;\
 var items = feed.querySelectorAll('.activity-item');\
 items.forEach(function(item) \{\
 // Skip if already has reply button\
 if (item.querySelector('.activity-reply-btn')) return;\
 // Skip if it's a presenter reply itself\
 if (item.classList.contains('presenter-reply')) return;\
 // Only add reply buttons to chat-type items (listener messages)\
 var icon = item.querySelector('.activity-icon.chat');\
 if (!icon) return;\
\
 // Grab the raw text for context\
 var textEl = item.querySelector('.activity-text');\
 if (!textEl) return;\
 var rawText = textEl.innerText || textEl.textContent || '';\
\
 var btn = document.createElement('button');\
 btn.className = 'activity-reply-btn';\
 btn.textContent = 'Reply';\
 btn.onclick = function(e) \{\
 e.stopPropagation();\
 openReplyModal(rawText);\
 \};\
 textEl.appendChild(btn);\
\
 // Track for reply context\
 _lastListenerMessages.push(\{ text: rawText, at: Date.now() \});\
 if (_lastListenerMessages.length > 20) _lastListenerMessages.shift();\
 \});\
\}\
