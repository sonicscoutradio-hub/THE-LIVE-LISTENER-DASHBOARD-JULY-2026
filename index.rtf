(function buildVibeGlobe() \{\
 var svg = document.getElementById('vibeGlobe');\
 if (!svg || typeof d3 === 'undefined') return;\
\
 var W = 600, H = 460;\
 var svgD3 = d3.select(svg);\
\
 var projection = d3.geoEquirectangular().scale(95).translate([W / 2, H / 2]);\
 var pathGen = d3.geoPath().projection(projection);\
\
 // Background rect\
 svgD3.append('rect')\
 .attr('class', 'vibe-globe-base')\
 .attr('x', 0).attr('y', 0)\
 .attr('width', W).attr('height', H)\
 .attr('rx', 4);\
\
 // Graticule\
 var graticule = d3.geoGraticule().step([30, 30]);\
 svgD3.append('path')\
 .attr('class', 'vibe-globe-graticule')\
 .attr('d', pathGen(graticule()));\
\
 // LAYER 1: Background simulated dots (250 dots across all populated cities)\
 var bgLayer = svgD3.append('g').attr('class', 'vibe-globe-bg-dots');\
\
 // LAYER 2: Live activity dots (accumulate during session)\
 var liveLayer = svgD3.append('g').attr('class', 'vibe-globe-live-dots');\
\
 // COUNTRY fills (async)\
 d3.json('https://cdn.jsdelivr.net/npm/world-atlas@2/countries-110m.json')\
 .then(function(world) \{\
 if (world && typeof topojson !== 'undefined') \{\
 var feat = topojson.feature(world, world.objects.countries);\
 svgD3.insert('path', '.vibe-globe-bg-dots')\
 .attr('d', pathGen(feat))\
 .attr('fill', 'rgba(232,112,10,0.72)')\
 .attr('stroke', 'rgba(255,170,60,0.9)')\
 .attr('stroke-width', 0.5);\
 \}\
 drawBackgroundDots();\
 \})\
 .catch(function() \{ drawBackgroundDots(); \});\
\
 // Tooltip\
 var tip = document.createElement('div');\
 tip.className = 'vibe-globe-tooltip';\
 tip.style.cssText = 'position:absolute;background:rgba(20,12,4,0.95);border:1px solid var(--amber);color:var(--text);font-size:11px;font-family:Syne,sans-serif;padding:5px 9px;border-radius:3px;pointer-events:none;opacity:0;transition:opacity 0.15s;z-index:50;white-space:nowrap;font-weight:700;letter-spacing:0.02em;';\
 if (svg.parentElement) \{\
 svg.parentElement.style.position = 'relative';\
 svg.parentElement.appendChild(tip);\
 \}\
\
 function showTip(label, evt) \{\
 var hostRect = svg.parentElement.getBoundingClientRect();\
 tip.textContent = label;\
 tip.style.left = (evt.clientX - hostRect.left + 8) + 'px';\
 tip.style.top = (evt.clientY - hostRect.top - 24) + 'px';\
 tip.style.opacity = '1';\
 \}\
 function hideTip() \{ tip.style.opacity = '0'; \}\
\
 function addDotToLayer(layer, cx, cy, r, fill, filter, label, className, extraStyle) \{\
 // Invisible larger hit-target for reliable hover detection on small dots\
 // (visible dot stays small, but mouse target is ~3x bigger)\
 var hitR = Math.max(r * 3, 7);\
 var hit = layer.append('circle')\
 .attr('class', (className || 'vibe-globe-dot') + '-hit')\
 .attr('cx', cx).attr('cy', cy)\
 .attr('r', hitR)\
 .style('fill', 'transparent')\
 .style('cursor', 'pointer')\
 .attr('data-label', label)\
 .attr('pointer-events', 'all');\
\
 var c = layer.append('circle')\
 .attr('class', className || 'vibe-globe-dot')\
 .attr('cx', cx).attr('cy', cy)\
 .attr('r', r)\
 .style('fill', fill)\
 .style('filter', filter)\
 .style('cursor', 'pointer')\
 .style('pointer-events', 'none') // let the hit circle handle hover\
 .attr('data-label', label);\
 if (extraStyle) Object.keys(extraStyle).forEach(function(k) \{ c.style(k, extraStyle[k]); \});\
\
 // Attach hover handlers to the larger hit circle, animate the visible dot\
 hit.on('mouseenter', function(evt) \{ showTip(label, evt); c.attr('r', r * 1.7); \})\
 .on('mouseleave', function() \{ hideTip(); c.attr('r', r); \})\
 .on('mousemove', function(evt) \{ showTip(label, evt); \});\
 return c;\
 \}\
\
 // DRAW LAYER 1: 250 background simulated dots \
 function drawBackgroundDots() \{\
 bgLayer.selectAll('*').remove();\
 var pool = _globeAllCities.slice();\
\
 // Shuffle pool\
 for (var i = pool.length - 1; i > 0; i--) \{\
 var j = Math.floor(Math.random() * (i + 1));\
 var tmp = pool[i]; pool[i] = pool[j]; pool[j] = tmp;\
 \}\
\
 // Pick 250 (or all if fewer)\
 var count = Math.min(250, pool.length);\
 for (var k = 0; k < count; k++) \{\
 var city = pool[k];\
 // Add small jitter so multiple dots from same city spread slightly\
 var lat = city.lat + (Math.random() - 0.5) * 1.2;\
 var lon = city.lon + (Math.random() - 0.5) * 1.8;\
 var p = projection([lon, lat]);\
 if (!p) continue;\
 var countryName = COUNTRY_NAMES_FULL[city.country] || city.country;\
 var label = city.name + ', ' + countryName;\
\
 addDotToLayer(\
 bgLayer, p[0], p[1],\
 1.6, // small background radius\
 'rgba(78,168,222,0.85)', // sky-blue background dots\
 'drop-shadow(0 0 2px rgba(78,168,222,0.5))',\
 label,\
 'vibe-bg-dot',\
 \{ opacity: (0.55 + Math.random() * 0.35).toFixed(2) \}\
 );\
 \}\
 \}\
\
 // DRAW LAYER 2: Live activity dot for a specific city \
 // Called externally when "Listener tuned in from [City]" appears in feed\
 window._vibeAddLiveCityDot = function(cityName, countryLabel) \{\
 // Try to find matching city in lookup\
 var found = null;\
 var searchName = (cityName || '').toLowerCase().trim();\
\
 // Search all cities\
 var allCodes = Object.keys(CITY_LOOKUP);\
 for (var ci = 0; ci < allCodes.length; ci++) \{\
 var cities = CITY_LOOKUP[allCodes[ci]];\
 for (var di = 0; di < cities.length; di++) \{\
 if (cities[di][2].toLowerCase() === searchName) \{\
 found = \{ lat: cities[di][0], lon: cities[di][1], name: cities[di][2], code: allCodes[ci] \};\
 break;\
 \}\
 \}\
 if (found) break;\
 \}\
\
 if (!found) return; // city not in lookup, skip silently\
\
 var p = projection([found.lon, found.lat]);\
 if (!p) return;\
 var countryName = COUNTRY_NAMES_FULL[found.code] || found.code;\
 var label = found.name + ', ' + countryName + '  live';\
\
 // Bright sky-blue live dot\
 var dot = addDotToLayer(\
 liveLayer, p[0], p[1],\
 4.5,\
 '#4ea8de',\
 'drop-shadow(0 0 4px rgba(78,168,222,0.9))',\
 label,\
 'vibe-live-dot',\
 \{ opacity: '0' \}\
 );\
\
 // Fade in\
 dot.transition().duration(400).style('opacity', '1');\
\
 // Emit a strong pulse ring\
 for (var ri = 0; ri < 2; ri++) \{\
 (function(delay) \{\
 setTimeout(function() \{\
 var ring = liveLayer.append('circle')\
 .attr('class', 'vibe-globe-live-ring')\
 .attr('cx', p[0]).attr('cy', p[1])\
 .attr('r', 4)\
 .style('fill', 'none')\
 .style('stroke', '#000000')\
 .style('stroke-width', '1.5')\
 .style('opacity', '0.7')\
 .style('pointer-events', 'none');\
 ring.transition().duration(1600).ease(d3.easeQuadOut)\
 .attr('r', 22)\
 .style('opacity', '0')\
 .on('end', function() \{ ring.remove(); \});\
 \}, delay);\
 \})(ri * 500);\
 \}\
\
 // Also pulse the dot itself (expand/contract loop 3 times then settle)\
 var pulseCount = 0;\
 function pulseDot() \{\
 if (pulseCount >= 4) return;\
 pulseCount++;\
 dot.transition().duration(400).attr('r', 7)\
 .transition().duration(400).attr('r', 4.5)\
 .on('end', pulseDot);\
 \}\
 pulseDot();\
 \};\
\
 // Sync legend count \
 function syncGlobeToCountries() \{\
 var liveEl = document.getElementById('liveCount');\
 var liveCount = parseInt((liveEl && liveEl.textContent) || '0', 10) || 0;\
 var legendEl = document.getElementById('vibeListenerCount');\
 if (legendEl) legendEl.textContent = '';\
 \}\
 syncGlobeToCountries();\
\
 // Gentle ambient pulse on background dots every ~2.2s \
 setInterval(function() \{\
 var bgDots = bgLayer.selectAll('.vibe-bg-dot').nodes();\
 if (bgDots.length === 0) return;\
 var dot = d3.select(bgDots[Math.floor(Math.random() * bgDots.length)]);\
 var cx = +dot.attr('cx'), cy = +dot.attr('cy');\
 var pulse = bgLayer.append('circle')\
 .attr('class', 'vibe-globe-pulse')\
 .attr('cx', cx).attr('cy', cy)\
 .attr('r', 1.5)\
 .style('fill', 'none')\
 .style('stroke', 'rgba(232,112,10,0.7)')\
 .style('stroke-width', '0.8')\
 .style('pointer-events', 'none');\
 pulse.transition().duration(1400).ease(d3.easeQuadOut)\
 .attr('r', 10).style('opacity', '0')\
 .on('end', function() \{ pulse.remove(); \});\
 \}, 2200);\
\
 // Occasionally pulse live dots too \
 setInterval(function() \{\
 var liveDots = liveLayer.selectAll('.vibe-live-dot').nodes();\
 if (liveDots.length === 0) return;\
 var dot = d3.select(liveDots[Math.floor(Math.random() * liveDots.length)]);\
 var cx = +dot.attr('cx'), cy = +dot.attr('cy');\
 var ring = liveLayer.append('circle')\
 .attr('cx', cx).attr('cy', cy).attr('r', 5)\
 .style('fill', 'none').style('stroke', '#000000').style('stroke-width', '1.2')\
 .style('opacity', '0.6').style('pointer-events', 'none');\
 ring.transition().duration(1200).ease(d3.easeQuadOut)\
 .attr('r', 18).style('opacity', '0')\
 .on('end', function() \{ ring.remove(); \});\
 \}, 1400);\
\
 // Re-sync legend when countries rotate\
 var _origRenderCountries = (typeof renderCountries === 'function') ? renderCountries : null;\
 if (_origRenderCountries) \{\
 renderCountries = function() \{\
 _origRenderCountries.apply(this, arguments);\
 setTimeout(syncGlobeToCountries, 100);\
 \};\
 \}\
\
 // Add viewer's own location (white dot, Layer 2) \
 window._vibeAddViewerLocation = function(lat, lon, cityName, regionName) \{\
 var p = projection([lon, lat]);\
