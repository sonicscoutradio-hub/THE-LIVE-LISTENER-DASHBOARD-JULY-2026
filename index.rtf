 // For each show, compute: how many complete airings this week, plus partial credit for a currently-running airing\
 function airingsCompletedForShow(showId) \{\
 // Total airings this week = sum over days and hours\
 // DAILY_SCHEDULE[h] gives the show id at hour h\
 var completeAirings = 0;\
 var partialFraction = 0; // 0-1 how far through current airing\
