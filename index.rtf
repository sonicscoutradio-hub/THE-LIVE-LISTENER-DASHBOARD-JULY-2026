.map-svg \{ width:100%; height:100%; \}\
.map-country \{ fill:rgba(60,42,24,.9); stroke:rgba(255,170,60,1); stroke-width:1.4; stroke-linejoin:round; stroke-linecap:round; \}\
.map-country:hover \{ fill:rgba(232,112,10,.5); stroke:rgba(255,200,100,1); \}\
