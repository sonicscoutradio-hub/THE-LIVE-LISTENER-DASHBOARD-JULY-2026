 text-align:center;\
\}\
.map-status.error .map-status-icon \{ opacity:1; \}\
.map-status.error .map-status-text \{ color:var(--live); \}\
\
@media (max-width: 460px) \{\
 .wrap \{ padding:12px 8px 40px; \}\
 .stats-strip \{ grid-template-columns:1fr 1fr; gap:6px; \}\
 .stat.hero \{ grid-column:1/-1; \}\
 .stat \{ padding:8px 10px; \}\
 .stat-big \{ font-size:20px; \}\
 .stat.hero .stat-big \{ font-size:26px; \}\
 .stat-label \{ font-size:8px; \}\
 .shows-grid \{ grid-template-columns:1fr; \}\
 .brand-text h1 \{ font-size:16px; \}\
 .brand-text p \{ font-size:10px; \}\
\}\
\
/* SIDE STACK (Activity + Trending) */\
.side-stack \{\
 display:flex; flex-direction:column; gap:22px;\
 min-height:0;\
\}\
.activity-panel, .trending-panel \{\
 display:flex; flex-direction:column;\
 flex:1; min-height:0;\
\}\
.pulse-dot \{\
 display:inline-block;\
 width:7px; height:7px;\
 background:var(--green);\
 border-radius:50%;\
 margin-right:6px;\
 box-shadow:0 0 0 0 var(--green);\
 animation:pulse-green 2s ease infinite;\
\}\
@keyframes pulse-green \{\
 0%,100% \{ box-shadow:0 0 0 0 rgba(62,207,142,.6); \}\
 50% \{ box-shadow:0 0 0 6px rgba(62,207,142,0); \}\
\}\
\
.activity-feed \{\
 padding:8px 0;\
 max-height:680px; /* ~15 items */\
 overflow-y:auto;\
 overflow-x:hidden;\
 position:relative;\
 scrollbar-width:thin;\
 scrollbar-color:var(--amber-dm) transparent;\
\}\
\
/* EDITORIAL PANELS (PRESENTER UPDATES / ARTIST SPOTLIGHT) */\
.editorial-grid \{\
 display: grid;\
 grid-template-columns: 1fr 1fr;\
 gap: 18px;\
 padding: 0 28px;\
 margin: 28px 0;\
\}\
@media (max-width: 900px) \{\
 .editorial-grid \{ grid-template-columns: 1fr; \}\
\}\
.ed-panel \{\
 border: 1px solid var(--amber-dm);\
 background: var(--bg-card);\
 display: flex;\
 flex-direction: column;\
\}\
.ed-panel-body \{\
 padding: 22px 24px;\
 display: flex;\
 flex-direction: column;\
 gap: 14px;\
 flex: 1;\
\}\
.ed-hero-line \{\
 font-family: 'Syne', sans-serif;\
 font-size: 18px;\
 font-weight: 700;\
 color: var(--amber-br);\
 line-height: 1.25;\
\}\
.ed-blurb \{\
 font-size: 12px;\
 line-height: 1.55;\
 color: var(--text);\
 margin: 0;\
\}\
.ed-list \{\
 display: flex;\
 flex-direction: column;\
 gap: 12px;\
 margin-top: 6px;\
 max-height: 480px;\
 overflow-y: auto;\
 scrollbar-width: thin;\
 scrollbar-color: var(--amber-dm) transparent;\
 padding-right: 4px;\
\}\
.ed-list::-webkit-scrollbar \{ width: 5px; \}\
.ed-list::-webkit-scrollbar-track \{ background: rgba(0,0,0,.2); \}\
.ed-list::-webkit-scrollbar-thumb \{ background: var(--amber-dm); border-radius: 2px; \}\
.ed-list::-webkit-scrollbar-thumb:hover \{ background: var(--amber); \}\
.ed-empty \{\
 padding: 36px 18px;\
 text-align: center;\
 color: var(--text);\
 font-size: 12px;\
 border: 1px dashed rgba(232,112,10,.25);\
 border-radius: 4px;\
\}\
.ed-empty-icon \{ display: block; font-size: 32px; margin-bottom: 10px; opacity: 0.85; \}\
.ed-empty-text \{ letter-spacing: 0.05em; \}\
.ed-presenter-post \{\
 background: rgba(232,112,10,0.05);\
 border-left: 3px solid var(--amber);\
 padding: 14px 16px;\
 border-radius: 0 4px 4px 0;\
 animation: ed-slide 0.4s ease;\
\}\
@keyframes ed-slide \{\
 from \{ opacity: 0; transform: translateY(-4px); \}\
 to \{ opacity: 1; transform: translateY(0); \}\
\}\
.ed-post-header \{\
 display: flex; align-items: baseline; justify-content: space-between;\
 gap: 12px; margin-bottom: 8px;\
\}\
.ed-post-presenter \{\
 font-family: 'Syne', sans-serif; font-weight: 700;\
 font-size: 13px; color: var(--amber-br);\
\}\
.ed-post-show \{\
 font-size: 10px; letter-spacing: 0.18em; color: var(--text); text-transform: uppercase;\
\}\
.ed-post-time \{\
 font-family: 'JetBrains Mono', monospace; font-size: 10px; color: var(--text); white-space: nowrap;\
\}\
.ed-post-message \{\
 font-size: 13px; line-height: 1.55; color: var(--text); white-space: pre-wrap;\
\}\
.ed-spotlight \{\
 background: rgba(232,112,10,0.05);\
 border-left: 3px solid var(--gold);\
 padding: 14px 16px;\
 border-radius: 0 4px 4px 0;\
 animation: ed-slide 0.4s ease;\
\}\
.ed-spot-type-badge \{\
 display: inline-block; font-family: 'JetBrains Mono', monospace;\
 font-size: 9px; letter-spacing: 0.22em;\
 padding: 3px 8px; background: rgba(212,164,64,0.18);\
 color: var(--gold); border-radius: 2px;\
 text-transform: uppercase; font-weight: 700; margin-bottom: 8px;\
\}\
.ed-spot-artist \{\
 font-family: 'Syne', sans-serif; font-weight: 700;\
 font-size: 18px; color: var(--text);\
 letter-spacing: -0.01em; margin-bottom: 6px;\
\}\
.ed-spot-detail \{ font-size: 12px; color: var(--text); margin-bottom: 4px; line-height: 1.5; \}\
.ed-spot-detail strong \{ color: var(--amber-br); font-weight: 600; \}\
.ed-spot-link \{\
 display: inline-block; margin-top: 6px; font-size: 11px; color: var(--amber);\
 text-decoration: none; border-bottom: 1px dashed var(--amber); padding-bottom: 1px;\
\}\
.ed-spot-link:hover \{ color: var(--amber-br); \}\
.ed-spot-message \{ font-size: 12px; line-height: 1.5; color: var(--text); margin-top: 8px; font-style: italic; \}\
.ed-spot-backed-by \{\
 margin-top: 10px; padding-top: 10px;\
 border-top: 1px dashed rgba(212,164,64,0.25);\
 font-size: 10px; letter-spacing: 0.12em; color: var(--text); text-transform: uppercase;\
\}\
.ed-spot-backed-by strong \{ color: var(--gold); \}\
.ed-spot-time \{\
 font-family: 'JetBrains Mono', monospace; font-size: 10px; color: var(--text); margin-top: 6px;\
\}\
\
/* Artist Voice  open posting form */\
.ap-form \{\
 background: rgba(232,112,10,0.04);\
 border: 1px solid rgba(232,112,10,0.25);\
 padding: 12px;\
 border-radius: 4px;\
 display: flex; flex-direction: column; gap: 8px;\
\}\
.ap-input, .ap-textarea \{\
 width: 100%; box-sizing: border-box;\
 padding: 8px 10px;\
 background: rgba(0,0,0,0.4);\
 border: 1px solid var(--amber-dm);\
 color: var(--text);\
 font-family: inherit;\
 font-size: 12px;\
 border-radius: 3px;\
\}\
.ap-input:focus, .ap-textarea:focus \{ outline: none; border-color: var(--amber); \}\
.ap-textarea \{ resize: vertical; min-height: 70px; line-height: 1.45; \}\
.ap-form-row \{\
 display: flex; justify-content: space-between; align-items: center;\
 margin-top: 2px;\
\}\
.ap-counter \{\
 font-family: 'JetBrains Mono', monospace;\
 font-size: 10px;\
 color: var(--text);\
\}\
.ap-submit \{\
 padding: 7px 16px;\
 background: var(--amber);\
 border: 1px solid var(--amber);\
 color: #000;\
 font-family: inherit;\
 font-size: 11px;\
 font-weight: 700;\
 letter-spacing: 0.08em;\
 text-transform: uppercase;\
 border-radius: 3px;\
 cursor: pointer;\
 transition: all 0.15s;\
\}\
.ap-submit:hover \{ background: var(--amber-br); border-color: var(--amber-br); \}\
.ap-submit:disabled \{ opacity: 0.5; cursor: wait; \}\
.ap-error \{\
 font-size: 11px;\
 color: #ff5060;\
 padding: 6px 8px;\
 border-left: 2px solid #ff5060;\
 background: rgba(255,80,96,0.06);\
 margin-top: 4px;\
\}\
.ap-feed \{ max-height: 320px; \}\
\
/* Artist post card (in the feed) */\
.ap-post \{\
 background: rgba(232,112,10,0.05);\
 border-left: 3px solid var(--gold);\
 padding: 11px 14px;\
 border-radius: 0 4px 4px 0;\
 animation: ed-slide 0.4s ease;\
\}\
.ap-post-header \{\
 display: flex; justify-content: space-between; align-items: baseline;\
 margin-bottom: 6px;\
\}\
.ap-post-handle \{\
 font-family: 'Syne', sans-serif;\
 font-weight: 700;\
 font-size: 13px;\
 color: var(--gold);\
 word-break: break-word;\
\}\
.ap-post-time \{\
 font-family: 'JetBrains Mono', monospace;\
 font-size: 10px;\
 color: var(--text);\
 white-space: nowrap;\
 margin-left: 8px;\
\}\
.ap-post-message \{\
 font-size: 12px;\
 line-height: 1.5;\
 color: var(--text);\
 white-space: pre-wrap;\
 word-break: break-word;\
\}\
.ap-post-link \{\
 display: inline-block;\
 margin-top: 6px;\
 font-size: 11px;\
 color: var(--amber);\
 text-decoration: none;\
 border-bottom: 1px dashed var(--amber);\
 word-break: break-all;\
\}\
.ap-post-link:hover \{ color: var(--amber-br); \}\
\
/* COMMAND CENTER PANELS */\
.cc-panels \{\
 display: grid;\
 grid-template-columns: 1fr 1.5fr;\
 gap: 1px;\
 background: var(--amber-dm);\
 border-top: 1px solid var(--amber-dm);\
 border-bottom: 1px solid var(--amber-dm);\
 margin: 0;\
\}\
.cc-panel \{\
 background: var(--bg-card);\
 padding: 18px 20px;\
 position: relative;\
 min-height: 240px;\
\}\
.cc-panel-header \{\
 margin-bottom: 14px;\
 padding-bottom: 10px;\
 border-bottom: 1px dashed rgba(232,112,10,0.18);\
\}\
.cc-panel-eyebrow \{\
 font-size: 9px;\
 letter-spacing: 0.28em;\
 color: var(--amber);\
 text-transform: uppercase;\
 font-weight: 600;\
 display: flex;\
 align-items: center;\
 gap: 8px;\
\}\
.cc-panel-eyebrow::before \{\
 content: '';\
 width: 5px; height: 5px;\
 background: var(--amber);\
 border-radius: 50%;\
 flex-shrink: 0;\
\}\
\
/* COUNTRIES list */\
.cc-countries-list \{\
 display: flex;\
 flex-direction: column;\
 gap: 6px;\
\}\
.cc-country-row \{\
 display: grid;\
 grid-template-columns: 24px 1fr auto;\
 gap: 10px;\
 align-items: center;\
 font-size: 11px;\
 position: relative;\
 animation: cc-slide 0.4s ease;\
\}\
@keyframes cc-slide \{\
 from \{ opacity: 0; transform: translateX(-6px); \}\
 to \{ opacity: 1; transform: translateX(0); \}\
\}\
.cc-flag \{\
 /* Country flag rendered as an <img> from flagcdn.com (cross-platform,\
 consistent  Windows doesn't render emoji flags natively). */\
 display:inline-flex;\
 align-items:center;\
 flex-shrink:0;\
\}\
.cc-flag img \{\
 width:22px; height:16px;\
 object-fit:cover;\
 border-radius:2px;\
 box-shadow:0 1px 2px rgba(0,0,0,0.4);\
 display:block;\
\}\
.cc-country-name-wrap \{\
 display: flex;\
 flex-direction: column;\
 min-width: 0;\
\}\
.cc-country-name \{\
 font-family: 'Syne', sans-serif;\
 font-weight: 700;\
 color: var(--text);\
 font-size: 12px;\
 letter-spacing: -0.01em;\
 white-space: nowrap;\
 overflow: hidden;\
 text-overflow: ellipsis;\
\}\
.cc-country-bar \{\
 height: 3px;\
 background: rgba(232,112,10,0.12);\
 margin-top: 3px;\
 overflow: hidden;\
 border-radius: 2px;\
\}\
.cc-country-bar-fill \{\
 height: 100%;\
 background: linear-gradient(90deg, var(--amber) 0%, var(--amber-br) 100%);\
 border-radius: 2px;\
 transition: width 0.6s ease;\
\}\
.cc-country-pct \{\
 font-family: 'JetBrains Mono', monospace;\
 font-weight: 700;\
 font-size: 12px;\
 color: var(--amber-br);\
 letter-spacing: 0.02em;\
 white-space: nowrap;\
\}\
\
/* WELCOME / Manifesto */\
.cc-welcome-body \{\
 font-size: 12px;\
 line-height: 1.65;\
 color: var(--text);\
\}\
.cc-welcome-body p \{ margin: 0 0 8px 0; \}\
.cc-welcome-body p:last-child \{ margin-bottom: 0; \}\
.cc-welcome-headline \{\
 font-family: 'Syne', sans-serif;\
 font-size: 14px !important;\
 font-weight: 700;\
 color: var(--amber-br) !important;\
 line-height: 1.4 !important;\
 margin-bottom: 10px !important;\
 letter-spacing: -0.01em;\
\}\
.cc-welcome-body strong \{\
 color: var(--amber);\
 font-weight: 700;\
\}\
.cc-welcome-tag \{\
 padding-top: 8px;\
 margin-top: 4px !important;\
 border-top: 1px dashed rgba(232,112,10,0.18);\
 font-size: 12px !important;\
 color: var(--text) !important;\
 font-style: normal;\
\}\
.cc-welcome-cta \{\
 font-family: 'Syne', sans-serif;\
 font-size: 13px !important;\
 color: var(--text) !important;\
 margin-top: 10px !important;\
 padding-top: 8px;\
 border-top: 1px dashed rgba(232,112,10,0.18);\
\}\
.cc-welcome-cta strong \{\
 color: var(--amber-br);\
\}\
\
/* App launch teaser */\
.cc-welcome-app \{\
 margin-top: 12px !important;\
 padding: 10px 14px !important;\
 border: 1px solid var(--amber);\
 background: linear-gradient(135deg, rgba(232,112,10,0.12), rgba(232,112,10,0.04));\
 border-radius: 4px;\
 display: flex !important;\
 align-items: center;\
 gap: 12px;\
 font-size: 12px !important;\
 position: relative;\
\}\
.cc-welcome-app::before \{\
 content: '';\
 font-size: 18px;\
 margin-right: 2px;\
\}\
.cc-welcome-app-eyebrow \{\
 font-family: 'JetBrains Mono', monospace;\
 font-size: 9px;\
 letter-spacing: 0.25em;\
 color: var(--amber);\
 text-transform: uppercase;\
 font-weight: 700;\
 white-space: nowrap;\
 padding: 3px 8px;\
 background: rgba(232,112,10,0.18);\
 border-radius: 2px;\
 flex-shrink: 0;\
\}\
.cc-welcome-app-text \{\
 color: var(--text);\
 font-size: 12px;\
 letter-spacing: 0.02em;\
 line-height: 1.3;\
\}\
.cc-welcome-app-text strong \{\
 color: var(--amber-br);\
 font-weight: 700;\
\}\
\
/* Mobile responsive: stack the two panels */\
@media (max-width: 720px) \{\
 .cc-panels \{\
 grid-template-columns: 1fr;\
 \}\
 .cc-panel \{\
 min-height: auto;\
 \}\
\}\
.activity-feed::-webkit-scrollbar \{\
 width:5px;\
\}\
.activity-feed::-webkit-scrollbar-track \{\
 background:rgba(0,0,0,.2);\
\}\
.activity-feed::-webkit-scrollbar-thumb \{\
 background:var(--amber-dm);\
 border-radius:2px;\
\}\
.activity-feed::-webkit-scrollbar-thumb:hover \{\
 background:var(--amber);\
\}\
.activity-item \{\
 display:flex; align-items:center; gap:10px;\
 padding:9px 18px;\
 font-size:12px;\
 border-bottom:1px dashed rgba(232,112,10,.1);\
 animation:slide-in .5s ease;\
\}\
@keyframes slide-in \{\
 from \{ transform:translateY(-10px); opacity:0; \}\
 to \{ transform:translateY(0); opacity:1; \}\
\}\
.activity-icon \{\
 width:20px; height:20px; flex-shrink:0;\
 display:flex; align-items:center; justify-content:center;\
 font-size:12px;\
 border-radius:50%;\
 font-family:'JetBrains Mono',monospace;\
\}\
.activity-icon.join \{ background:rgba(62,207,142,.15); color:var(--green); \}\
.activity-icon.play \{ background:rgba(232,112,10,.15); color:var(--amber); \}\
.activity-icon.chat \{ background:rgba(78,168,222,.15); color:var(--sky); \}\
.activity-icon.peak \{ background:rgba(255,56,96,.15); color:var(--live); \}\
.activity-text \{\
 flex:1; min-width:0;\
 color:var(--text);\
 white-space:nowrap; overflow:hidden; text-overflow:ellipsis;\
\}\
.activity-text .accent \{ color:var(--amber-br); font-weight:600; \}\
.activity-time \{\
 font-family:'JetBrains Mono',monospace;\
 font-size:10px;\
 color:var(--text);\
 flex-shrink:0;\
\}\
\
/* TRENDING TRACKS */\
.trending-list \{\
 padding:4px 0;\
\}\
.trending-item \{\
 display:flex; align-items:center; gap:12px;\
 padding:10px 18px;\
 border-bottom:1px dashed rgba(232,112,10,.1);\
 transition:background .15s;\
\}\
.trending-item:hover \{ background:rgba(232,112,10,.04); \}\
.trending-item:last-child \{ border-bottom:none; \}\
.trending-rank \{\
 font-family:'Syne',sans-serif;\
 font-weight:800; font-size:18px;\
 color:var(--amber-br);\
 width:28px;\
 text-align:center;\
\}\
.trending-info \{ flex:1; min-width:0; \}\
.trending-song \{\
 font-family:'Syne',sans-serif;\
 font-weight:700;\
 font-size:13px;\
 color:var(--text);\
 line-height:1.2;\
 margin-bottom:2px;\
 white-space:nowrap; overflow:hidden; text-overflow:ellipsis;\
\}\
.trending-artist \{\
 font-family:'JetBrains Mono',monospace;\
 font-size:10px;\
 letter-spacing:.1em;\
 color:var(--amber);\
 text-transform:uppercase;\
 white-space:nowrap; overflow:hidden; text-overflow:ellipsis;\
\}\
.trending-plays \{\
 font-family:'JetBrains Mono',monospace;\
 font-size:13px;\
 color:var(--text);\
 font-weight:500;\
 text-align:right;\
\}\
.trending-plays-lbl \{\
 font-size:8px;\
 color:var(--text-mute);\
 letter-spacing:.2em;\
 text-transform:uppercase;\
 margin-top:1px;\
\}\
\
/* FULL WIDTH MAP */\
/* 3-PANEL INFO SECTION (Schedule | Top Tracks | Subscriptions) */\
.info-grid \{\
 margin-top:24px;\
 display:grid;\
 grid-template-columns:1fr 1fr 1fr;\
 gap:18px;\
 align-items:stretch;\
\}\
.info-panel \{\
 display:flex;\
 flex-direction:column;\
 min-height:720px;\
\}\
.info-panel-body \{\
 padding:18px 20px 20px;\
 flex:1;\
 display:flex;\
 flex-direction:column;\
 gap:14px;\
 overflow:hidden;\
\}\
.info-hero-line \{\
 font-family:'Syne',sans-serif;\
 font-size:18px;\
 font-weight:700;\
 color:var(--amber-br);\
 line-height:1.3;\
 letter-spacing:-.01em;\
\}\
.info-blurb \{\
 font-size:12px;\
 color:var(--text);\
 line-height:1.6;\
 margin:0;\
 letter-spacing:.01em;\
\}\
\
/* SCHEDULE PANEL */\
.schedule-section-title \{\
 font-family:'JetBrains Mono',monospace;\
 font-size:10px;\
 letter-spacing:.25em;\
 color:var(--amber);\
 text-transform:uppercase;\
 margin-top:6px;\
 padding-bottom:6px;\
 border-bottom:1px dashed rgba(232,112,10,.25);\
 display:flex;\
 justify-content:space-between;\
 align-items:baseline;\
\}\
.schedule-tz \{\
 font-size:9px;\
 color:var(--text-dm);\
 letter-spacing:.15em;\
\}\
.schedule-list \{\
 display:flex;\
 flex-direction:column;\
 gap:2px;\
 overflow-y:auto;\
 flex:1;\
 padding-right:6px;\
 scrollbar-width:thin;\
 scrollbar-color:var(--amber-dm) transparent;\
\}\
.schedule-list::-webkit-scrollbar \{ width:4px; \}\
.schedule-list::-webkit-scrollbar-track \{ background:transparent; \}\
.schedule-list::-webkit-scrollbar-thumb \{ background:var(--amber-dm); border-radius:2px; \}\
.sched-item \{\
 display:grid;\
 grid-template-columns:50px 1fr auto;\
 gap:10px;\
 padding:7px 8px;\
 font-size:11px;\
 align-items:center;\
 border-bottom:1px solid rgba(232,112,10,.06);\
 transition:background .15s;\
\}\
.sched-item:hover \{\
 background:rgba(232,112,10,.05);\
\}\
.sched-time \{\
 font-family:'JetBrains Mono',monospace;\
 font-size:10px;\
 color:var(--amber);\
 font-weight:600;\
 letter-spacing:.05em;\
\}\
.sched-show \{\
 font-family:'Syne',sans-serif;\
 font-weight:600;\
 color:var(--text);\
 font-size:12px;\
 display:flex;\
 align-items:center;\
 gap:6px;\
\}\
.sched-host \{\
 font-family:'JetBrains Mono',monospace;\
 font-size:9px;\
 color:var(--amber);\
 letter-spacing:.05em;\
 text-align:right;\
 font-weight:600;\
\}\
.sched-new \{\
 background:linear-gradient(90deg, rgba(232,112,10,.08), transparent 70%);\
