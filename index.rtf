 if (DAILY_SCHEDULE[h] === showId) completeAirings++;\
 \}\
 // Check if show is currently mid-airing (only relevant for today)\
 if (d === daysSinceMonday) \{\
 if (DAILY_SCHEDULE[estDate.getHours()] === showId) \{\
