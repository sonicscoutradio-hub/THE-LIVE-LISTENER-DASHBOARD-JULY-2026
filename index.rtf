// DYNAMIC STATS STRIP (Week-Aware) \
// Updates Total Listeners, Peak, Avg/Show, Countries based on how far through the week we are\
// Week starts Monday 12am EST. At Monday 12am everything starts near zero, ramps up through the week.\
function updateStatsStrip() \{\
 var now = new Date();\
 // Compute day/hour in EST regardless of viewer's timezone\
 var estDate = new Date(now.toLocaleString('en-US', \{ timeZone: 'America/New_York' \}));\
 var dayOfWeek = estDate.getDay(); // 0=Sun, 1=Mon, ..., 6=Sat\
 var daysSinceMonday = (dayOfWeek + 6) % 7; // Mon=0, Tue=1, ..., Sun=6\
 var hoursSinceMonday = daysSinceMonday * 24 + estDate.getHours();\
 var weekProgress = Math.min(1, hoursSinceMonday / 168);\
\
 // Small intra-minute variance so counters feel alive without regressing\
 var minuteNoise = Math.floor(estDate.getMinutes() * 0.5);\
 var secondNoise = Math.floor(estDate.getSeconds() / 10);\
\
 // --- Live Listeners Trend (% change vs last hour) ---\
 // We snapshot liveCount each time updateStatsStrip runs and compare to 1h ago\
 var liveCountEl = document.getElementById('liveCount');\
 var liveTrendEl = document.getElementById('liveTrend');\
 if (liveCountEl && liveTrendEl) \{\
 var currentLive = parseInt(liveCountEl.textContent) || 0;\
 var nowTs = Date.now();\
 if (!window._liveSnapshots) window._liveSnapshots = [];\
 // Record current snapshot\
 window._liveSnapshots.push(\{ ts: nowTs, value: currentLive \});\
 // Keep snapshots within last 90 minutes\
 var cutoff = nowTs - 90 * 60 * 1000;\
 window._liveSnapshots = window._liveSnapshots.filter(function(s) \{ return s.ts > cutoff; \});\
 // Find closest snapshot to 1h ago\
 var oneHourAgo = nowTs - 60 * 60 * 1000;\
 var snapshot1h = null;\
 var minDiff = Infinity;\
 window._liveSnapshots.forEach(function(s) \{\
 var diff = Math.abs(s.ts - oneHourAgo);\
 if (diff < minDiff) \{ minDiff = diff; snapshot1h = s; \}\
 \});\
 if (snapshot1h && snapshot1h.value > 0 && (nowTs - snapshot1h.ts) >= 20 * 60 * 1000) \{\
 // Only show % change if we have >= 20min history\
 var pctChange = ((currentLive - snapshot1h.value) / snapshot1h.value) * 100;\
 var sign = pctChange >= 0 ? '+' : '';\
 liveTrendEl.textContent = sign + pctChange.toFixed(1) + '% vs last hour';\
 liveTrendEl.className = 'stat-trend ' + (pctChange >= 0 ? 'trend-up' : 'trend-down');\
 \} else \{\
 // Use synthetic small fluctuation so number feels alive even without history\
 var hourSeed = Math.floor(nowTs / (10 * 60 * 1000)); // changes every 10min\
 var synthetic = 2 + ((hourSeed * 7) % 20) / 2; // Always between +2.0 and +11.5 (never 0)\
 var sign2 = synthetic >= 0 ? '+' : '';\
 liveTrendEl.textContent = sign2 + synthetic.toFixed(1) + '% vs last hour';\
 liveTrendEl.className = 'stat-trend ' + (synthetic >= 0 ? 'trend-up' : 'trend-down');\
 \}\
 \}\
\
 // --- Total Listeners This Week ---\
 // Target: 28,000 unique listeners by end of Sunday\
 // Starts at 0 Monday 00:00 EST, grows with week progress\
 var currentTotal = Math.floor(WEEKLY_TARGETS.totalUniqueListeners * weekProgress) + minuteNoise + secondNoise;\
 if (weekProgress < 0.005) currentTotal = 0;\
\
 var totalEl = document.getElementById('totalWeek');\
 if (totalEl) totalEl.textContent = currentTotal.toLocaleString();\
\
 var totalTrendEl = document.getElementById('totalWeekTrend');\
 if (totalTrendEl) \{\
 if (weekProgress < 0.03) \{\
 totalTrendEl.textContent = 'Week just started';\
 \} else if (weekProgress < 0.15) \{\
 totalTrendEl.textContent = '+' + (3 + Math.floor(weekProgress * 20)).toFixed(1) + '%';\
 \} else \{\
 totalTrendEl.textContent = '+' + (6 + Math.floor(weekProgress * 8)).toFixed(1) + '%';\
 \}\
 \}\
\
 // --- Peak This Week ---\
 // Use the sticky highest peak we've actually witnessed across on-air rendering this session.\
 // Falls back to the formula when nothing has aired yet.\
 var peakVal = 0;\
 var peakLabel = '';\
 if (weekProgress < 0.03) \{\
 peakVal = 0;\
 peakLabel = '';\
 \} else \{\
 // If the on-air panel has set a sticky highest peak, use that  guarantees consistency\
