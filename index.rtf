 \} else if (replyModal && replyModal.style.display === 'flex') \{\
 // Allow Shift+Enter for newline, Enter to send\
 if (!e.shiftKey && e.target.id === 'presenterReplyText') \{\
 e.preventDefault();\
 submitPresenterReply();\
 \}\
 \}\
 \}\
 if (e.key === 'Escape') \{\
 closePresenterLogin();\
 closePresenterReply();\
 \}\
\});\
\
