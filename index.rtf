 <!-- ============================================================\
      DISCOVERY POOL ANIMATED PANEL (3rd column of .info-grid)\
      Self-contained: scoped under .ssr-pool.\
      ============================================================ -->\
<!--\
  ============================================================\
  SSR LIVE \'97 DISCOVERY POOL ANIMATED PANEL  (v2)\
  Drop-in snippet for the right column of the .info-grid on\
  the Live Listener Dashboard.\
\
  Self-contained: <style> + <section>. No JS required.\
  All motion via CSS keyframes + SVG. Respects\
  prefers-reduced-motion.\
\
  Scope: every selector under .ssr-pool so nothing leaks.\
  ============================================================\
-->\
\
<style>\
/* ============================================================\
   DISCOVERY POOL PANEL\
   ============================================================ */\
.ssr-pool \{\
  position: relative;\
  width: 100%;\
  min-height: 720px;\
  background:\
    radial-gradient(ellipse at 50% 20%, rgba(255,149,0, 0.22) 0%, transparent 55%),\
    radial-gradient(ellipse at 50% 100%, rgba(255,45,111, 0.16) 0%, transparent 55%),\
    radial-gradient(circle at center, #15110c 0%, #0a0806 80%);\
  border: 1.5px solid rgba(232,112,10, 0.45);\
  border-radius: 14px;\
  color: #f5f0e8;\
  overflow: hidden;\
  font-family: Arial, Helvetica, sans-serif;\
  display: flex;\
  flex-direction: column;\
  padding: 20px 20px 16px;\
  box-sizing: border-box;\
  box-shadow: 0 0 60px rgba(232,112,10, 0.10);\
\}\
\
/* subtle grid */\
.ssr-pool::before \{\
  content: "";\
  position: absolute; inset: 0;\
  background-image:\
    linear-gradient(rgba(255,255,255,0.025) 1px, transparent 1px),\
    linear-gradient(90deg, rgba(255,255,255,0.025) 1px, transparent 1px);\
  background-size: 40px 40px;\
  pointer-events: none;\
\}\
.ssr-pool > * \{ position: relative; z-index: 2; \}\
\
/* ============================================================\
   HEADER\
   ============================================================ */\
.ssr-pool-head \{\
  display: flex;\
  align-items: center;\
  justify-content: space-between;\
  margin-bottom: 6px;\
\}\
.ssr-pool-head .label \{\
  font-family: 'JetBrains Mono', Menlo, Monaco, Consolas, monospace;\
  font-size: 11px;\
  letter-spacing: 0.28em;\
  text-transform: uppercase;\
  color: #e8700a;\
  font-weight: 700;\
  display: inline-flex;\
  align-items: center;\
  gap: 8px;\
\}\
.ssr-pool-head .label::before \{\
  content: "\\25C6";   /* diamond */\
  font-size: 10px;\
  color: #e8700a;\
\}\
\
/* LIVE badge */\
.ssr-pool-live \{\
  display: inline-flex;\
  align-items: center;\
  gap: 8px;\
  font-family: 'JetBrains Mono', Menlo, Monaco, Consolas, monospace;\
  font-size: 10px;\
  letter-spacing: 0.3em;\
  color: #2bd97a;\
  background: rgba(43,217,122, 0.12);\
  border: 1px solid rgba(43,217,122, 0.55);\
  padding: 5px 11px;\
  border-radius: 3px;\
  text-transform: uppercase;\
  font-weight: 700;\
\}\
.ssr-pool-live .dot \{\
  width: 8px; height: 8px;\
  background: #2bd97a;\
  border-radius: 50%;\
  box-shadow: 0 0 0 0 rgba(43,217,122, 0.7);\
  animation: ssr-pool-live-pulse 1.4s infinite;\
\}\
@keyframes ssr-pool-live-pulse \{\
  0%   \{ box-shadow: 0 0 0 0   rgba(43,217,122, 0.7); \}\
  70%  \{ box-shadow: 0 0 0 12px rgba(43,217,122, 0); \}\
  100% \{ box-shadow: 0 0 0 0   rgba(43,217,122, 0); \}\
\}\
\
/* ============================================================\
   TITLE\
   ============================================================ */\
.ssr-pool-title \{\
  margin: 12px 0 4px;\
  font-family: Impact, 'Arial Black', 'Helvetica Neue', Arial, sans-serif;\
  font-size: clamp(1.7rem, 5vw, 2.2rem);\
  line-height: 0.95;\
  text-transform: uppercase;\
  letter-spacing: 0.025em;\
  color: #f5f0e8;\
\}\
.ssr-pool-title .accent \{\
  display: block;\
  background: linear-gradient(135deg, #ff9500 0%, #ffb15e 100%);\
  -webkit-background-clip: text;\
  -webkit-text-fill-color: transparent;\
  background-clip: text;\
\}\
.ssr-pool-sub \{\
  font-size: 12.5px;\
  line-height: 1.55;\
  color: #c9c4bd;\
  margin: 0 0 12px;\
\}\
.ssr-pool-sub strong \{ color: #2bd97a; font-weight: 800; \}\
\
/* ============================================================\
   STAGE \'97 animated visual\
   ============================================================ */\
.ssr-pool-stage \{\
  position: relative;\
  width: 100%;\
  aspect-ratio: 1 / 1;\
  margin: 4px 0 10px;\
  display: flex;\
  align-items: center;\
  justify-content: center;\
\}\
\
/* sweeping radar arc */\
.ssr-pool-radar \{\
  position: absolute;\
  inset: 0;\
  border-radius: 50%;\
  background: conic-gradient(\
    from 0deg,\
    rgba(232,112,10, 0)   0deg,\
    rgba(232,112,10, 0)   270deg,\
    rgba(232,112,10, 0.55) 350deg,\
    rgba(255,149,0,  0.85) 358deg,\
    rgba(255,149,0,  0)   360deg\
  );\
  mask: radial-gradient(circle, transparent 30%, #000 31%, #000 88%, transparent 89%);\
  -webkit-mask: radial-gradient(circle, transparent 30%, #000 31%, #000 88%, transparent 89%);\
  animation: ssr-pool-radar-spin 5s linear infinite;\
\}\
@keyframes ssr-pool-radar-spin \{\
  0%   \{ transform: rotate(0deg); \}\
  100% \{ transform: rotate(360deg); \}\
\}\
\
/* expanding ripples */\
.ssr-pool-ripples \{\
  position: absolute; inset: 0;\
  pointer-events: none;\
\}\
.ssr-pool-ripples span \{\
  position: absolute; inset: 0;\
  border: 2px solid rgba(255,149,0, 0.55);\
  border-radius: 50%;\
  animation: ssr-pool-ripple 5s infinite ease-out;\
  opacity: 0;\
\}\
.ssr-pool-ripples span:nth-child(1) \{ animation-delay: 0s;    \}\
.ssr-pool-ripples span:nth-child(2) \{ animation-delay: 1.25s; \}\
.ssr-pool-ripples span:nth-child(3) \{ animation-delay: 2.5s;  \}\
.ssr-pool-ripples span:nth-child(4) \{ animation-delay: 3.75s; \}\
@keyframes ssr-pool-ripple \{\
  0%   \{ transform: scale(0.05); opacity: 1; border-width: 2.5px; \}\
  100% \{ transform: scale(1);    opacity: 0; border-width: 1px; \}\
\}\
\
/* fixed guide rings */\
.ssr-pool-rings \{\
  position: absolute;\
  inset: 4%;\
  border-radius: 50%;\
  border: 1px solid rgba(255,149,0, 0.18);\
\}\
.ssr-pool-rings::before,\
.ssr-pool-rings::after \{\
  content: "";\
  position: absolute;\
  border-radius: 50%;\
  border: 1px solid rgba(255,149,0, 0.18);\
\}\
.ssr-pool-rings::before \{ inset: 16%; \}\
.ssr-pool-rings::after  \{ inset: 32%; border: 1px dashed rgba(255,149,0, 0.30); animation: ssr-pool-spin-slow 22s linear infinite; \}\
@keyframes ssr-pool-spin-slow \{\
  0%   \{ transform: rotate(0deg); \}\
  100% \{ transform: rotate(360deg); \}\
\}\
\
/* ============================================================\
   MUSICAL NOTES \'97 multi-color, orbiting + bobbing\
   ============================================================ */\
.ssr-pool-notes \{\
  position: absolute; inset: 0;\
  pointer-events: none;\
\}\
.ssr-pool-notes .note \{\
  position: absolute;\
  font-family: 'Lucida Sans Unicode', 'Arial Unicode MS', 'Apple Symbols', sans-serif;\
  font-weight: 700;\
  text-shadow: 0 0 14px currentColor;\
  line-height: 1;\
  animation: ssr-pool-note-bob 4s ease-in-out infinite;\
\}\
.ssr-pool-notes .n1 \{ top:  6%; left: 22%; color:#ff9500; font-size: 30px; animation-delay: 0s;    \}\
.ssr-pool-notes .n2 \{ top: 14%; left: 76%; color:#ff2d6f; font-size: 26px; animation-delay: 0.4s; \}\
.ssr-pool-notes .n3 \{ top: 44%; left:  6%; color:#4ea8de; font-size: 24px; animation-delay: 0.8s; \}\
.ssr-pool-notes .n4 \{ top: 44%; left: 88%; color:#2bd97a; font-size: 28px; animation-delay: 1.2s; \}\
.ssr-pool-notes .n5 \{ top: 78%; left: 14%; color:#ffd86b; font-size: 26px; animation-delay: 1.6s; \}\
.ssr-pool-notes .n6 \{ top: 80%; left: 74%; color:#ffb15e; font-size: 32px; animation-delay: 2.0s; \}\
.ssr-pool-notes .n7 \{ top: 28%; left: 50%; color:#c98cff; font-size: 22px; animation-delay: 2.4s; transform: translateX(-50%); \}\
.ssr-pool-notes .n8 \{ top: 86%; left: 48%; color:#ff6680; font-size: 24px; animation-delay: 2.8s; transform: translateX(-50%); \}\
@keyframes ssr-pool-note-bob \{\
  0%, 100% \{ transform: translateY(0)    rotate(-4deg); opacity: 0.9; \}\
  50%      \{ transform: translateY(-10px) rotate(6deg);  opacity: 1;   \}\
\}\
/* centred notes keep their X translate */\
.ssr-pool-notes .n7 \{ transform-origin: center; \}\
.ssr-pool-notes .n7 \{ animation-name: ssr-pool-note-bob-center; \}\
.ssr-pool-notes .n8 \{ animation-name: ssr-pool-note-bob-center; \}\
@keyframes ssr-pool-note-bob-center \{\
  0%, 100% \{ transform: translateX(-50%) translateY(0)    rotate(-4deg); opacity: 0.9; \}\
  50%      \{ transform: translateX(-50%) translateY(-10px) rotate(6deg);  opacity: 1;   \}\
\}\
\
/* center mic disc */\
.ssr-pool-core \{\
  position: relative;\
  width: 30%;\
  aspect-ratio: 1 / 1;\
  border-radius: 50%;\
  background:\
    radial-gradient(circle at 50% 40%, rgba(255,149,0, 0.35), transparent 65%),\
    #0a0806;\
  border: 2px solid #ff9500;\
  display: flex;\
  align-items: center;\
  justify-content: center;\
  box-shadow:\
    0 0 40px rgba(255,149,0, 0.55),\
    inset 0 0 24px rgba(255,149,0, 0.20);\
  animation: ssr-pool-core-glow 2.6s ease-in-out infinite alternate;\
  z-index: 3;\
\}\
@keyframes ssr-pool-core-glow \{\
  0%   \{ box-shadow: 0 0 28px rgba(255,149,0, 0.40), inset 0 0 18px rgba(255,149,0, 0.18); \}\
  100% \{ box-shadow: 0 0 56px rgba(255,149,0, 0.80), inset 0 0 28px rgba(255,149,0, 0.32); \}\
\}\
.ssr-pool-core svg \{\
  width: 60%; height: 60%;\
  filter: drop-shadow(0 0 6px rgba(255,149,0, 0.6));\
\}\
\
/* sparkles */\
.ssr-pool-sparkles \{\
  position: absolute; inset: 0;\
  pointer-events: none;\
\}\
.ssr-pool-sparkles i \{\
  position: absolute;\
  width: 4px; height: 4px;\
  border-radius: 50%;\
  background: #ffb15e;\
  opacity: 0.7;\
  animation: ssr-pool-twinkle 2.2s ease-in-out infinite alternate;\
\}\
.ssr-pool-sparkles i:nth-child(1) \{ top: 36%; left: 32%; animation-delay: 0.0s; \}\
.ssr-pool-sparkles i:nth-child(2) \{ top: 60%; left: 68%; animation-delay: 0.4s; background:#ff2d6f; \}\
.ssr-pool-sparkles i:nth-child(3) \{ top: 56%; left: 28%; animation-delay: 0.8s; background:#2bd97a; \}\
.ssr-pool-sparkles i:nth-child(4) \{ top: 40%; left: 66%; animation-delay: 1.1s; \}\
@keyframes ssr-pool-twinkle \{\
  0%   \{ opacity: 0.15; transform: scale(0.6); \}\
  100% \{ opacity: 1;    transform: scale(1.3); \}\
\}\
\
/* ============================================================\
   NOW REVIEWING TICKER \'97 absolute-positioned fade cycle\
   (one show visible at a time, clean clipping, no peek)\
   ============================================================ */\
.ssr-pool-ticker \{\
  background: rgba(255,149,0, 0.08);\
  border: 1px solid rgba(255,149,0, 0.35);\
  border-radius: 8px;\
  padding: 10px 12px;\
  margin-bottom: 10px;\
  display: flex;\
  align-items: center;\
  gap: 10px;\
\}\
.ssr-pool-ticker .tag \{\
  font-family: 'JetBrains Mono', Menlo, Monaco, Consolas, monospace;\
  font-size: 10px;\
  letter-spacing: 0.24em;\
  color: #e8700a;\
  font-weight: 800;\
  text-transform: uppercase;\
  flex-shrink: 0;\
\}\
.ssr-pool-ticker .stream \{\
  position: relative;\
  flex: 1;\
  height: 24px;\
  overflow: hidden;\
\}\
.ssr-pool-ticker .show \{\
  position: absolute;\
  inset: 0;\
  display: flex;\
  align-items: center;\
  font-size: 13.5px;\
  font-weight: 700;\
  color: #fff;\
  white-space: nowrap;\
  opacity: 0;\
  animation: ssr-pool-show-fade 32s linear infinite;\
\}\
.ssr-pool-ticker .show b \{ color: #ff9500; margin-right: 6px; \}\
.ssr-pool-ticker .show em \{ font-style: normal; color: #d8d2c8; font-weight: 600; \}\
/* 16 shows \'d7 2s = 32s total. 6.25% per slot. Visible ~5% (=1.6s), gap covers the rest. */\
.ssr-pool-ticker .show:nth-child(1)  \{ animation-delay: 0s;    \}\
.ssr-pool-ticker .show:nth-child(2)  \{ animation-delay: -30s;  \}\
.ssr-pool-ticker .show:nth-child(3)  \{ animation-delay: -28s;  \}\
.ssr-pool-ticker .show:nth-child(4)  \{ animation-delay: -26s;  \}\
.ssr-pool-ticker .show:nth-child(5)  \{ animation-delay: -24s;  \}\
.ssr-pool-ticker .show:nth-child(6)  \{ animation-delay: -22s;  \}\
.ssr-pool-ticker .show:nth-child(7)  \{ animation-delay: -20s;  \}\
.ssr-pool-ticker .show:nth-child(8)  \{ animation-delay: -18s;  \}\
.ssr-pool-ticker .show:nth-child(9)  \{ animation-delay: -16s;  \}\
.ssr-pool-ticker .show:nth-child(10) \{ animation-delay: -14s;  \}\
.ssr-pool-ticker .show:nth-child(11) \{ animation-delay: -12s;  \}\
.ssr-pool-ticker .show:nth-child(12) \{ animation-delay: -10s;  \}\
.ssr-pool-ticker .show:nth-child(13) \{ animation-delay:  -8s;  \}\
.ssr-pool-ticker .show:nth-child(14) \{ animation-delay:  -6s;  \}\
.ssr-pool-ticker .show:nth-child(15) \{ animation-delay:  -4s;  \}\
.ssr-pool-ticker .show:nth-child(16) \{ animation-delay:  -2s;  \}\
@keyframes ssr-pool-show-fade \{\
  0%   \{ opacity: 0; transform: translateY(6px); \}\
  1%   \{ opacity: 1; transform: translateY(0);   \}\
  6%   \{ opacity: 1; transform: translateY(0);   \}\
  7%   \{ opacity: 0; transform: translateY(-6px);\}\
  100% \{ opacity: 0; transform: translateY(-6px);\}\
\}\
\
/* ============================================================\
   EQUALIZER BARS\
   ============================================================ */\
.ssr-pool-eq \{\
  display: flex;\
  align-items: flex-end;\
  justify-content: center;\
  gap: 4px;\
  height: 46px;\
  margin: 4px 0 12px;\
\}\
.ssr-pool-eq span \{\
  flex: 1;\
  background: linear-gradient(to top, #e8700a 0%, #ff9c3a 100%);\
  border-radius: 2px;\
  min-height: 6px;\
  box-shadow: 0 0 8px rgba(232,112,10, 0.55);\
  animation: ssr-pool-eq-bounce 1.3s infinite ease-in-out;\
\}\
.ssr-pool-eq span:nth-child(1)  \{ animation-delay: 0.00s; \}\
.ssr-pool-eq span:nth-child(2)  \{ animation-delay: 0.10s; \}\
.ssr-pool-eq span:nth-child(3)  \{ animation-delay: 0.20s; \}\
.ssr-pool-eq span:nth-child(4)  \{ animation-delay: 0.30s; \}\
.ssr-pool-eq span:nth-child(5)  \{ animation-delay: 0.40s; \}\
.ssr-pool-eq span:nth-child(6)  \{ animation-delay: 0.50s; \}\
.ssr-pool-eq span:nth-child(7)  \{ animation-delay: 0.60s; \}\
.ssr-pool-eq span:nth-child(8)  \{ animation-delay: 0.50s; \}\
.ssr-pool-eq span:nth-child(9)  \{ animation-delay: 0.40s; \}\
.ssr-pool-eq span:nth-child(10) \{ animation-delay: 0.30s; \}\
.ssr-pool-eq span:nth-child(11) \{ animation-delay: 0.20s; \}\
.ssr-pool-eq span:nth-child(12) \{ animation-delay: 0.10s; \}\
.ssr-pool-eq span:nth-child(13) \{ animation-delay: 0.00s; \}\
.ssr-pool-eq span:nth-child(14) \{ animation-delay: 0.15s; \}\
.ssr-pool-eq span:nth-child(15) \{ animation-delay: 0.30s; \}\
.ssr-pool-eq span:nth-child(16) \{ animation-delay: 0.45s; \}\
@keyframes ssr-pool-eq-bounce \{\
  0%, 100% \{ height: 14%; \}\
  20%      \{ height: 80%; \}\
  40%      \{ height: 36%; \}\
  60%      \{ height: 100%; \}\
  80%      \{ height: 52%; \}\
\}\
\
/* ============================================================\
   CTA\
   ============================================================ */\
.ssr-pool-cta \{\
  margin-top: auto;\
  text-align: center;\
  padding-top: 4px;\
\}\
.ssr-pool-cta .line \{\
  font-size: 13px;\
  color: #fff;\
  font-weight: 700;\
  line-height: 1.45;\
  margin-bottom: 10px;\
\}\
.ssr-pool-cta .line .or \{ color: #ff9500; font-weight: 900; \}\
/* === STORE BADGES (App Store + Google Play) === */\
.ssr-pool-stores \{\
  display: flex;\
  flex-wrap: wrap;\
  gap: 10px;\
  justify-content: center;\
  margin-top: 4px;\
\}\
.ssr-pool-store \{\
  display: inline-flex;\
  align-items: center;\
  gap: 10px;\
  background: #000;\
  color: #fff;\
  border: 1.5px solid rgba(255,255,255,0.55);\
  border-radius: 10px;\
  padding: 9px 14px;\
  text-decoration: none;\
  flex: 1 1 0;\
  min-width: 0;\
  max-width: 200px;\
  transition: transform 0.2s ease, box-shadow 0.2s ease, border-color 0.2s ease;\
  box-shadow: 0 0 12px rgba(255,149,0, 0.18);\
\}\
.ssr-pool-store:hover \{\
  transform: translateY(-2px);\
  border-color: #ff9500;\
  box-shadow: 0 0 24px rgba(255,149,0, 0.55);\
\}\
.ssr-pool-store svg \{\
  width: 26px; height: 26px; flex-shrink: 0;\
\}\
.ssr-pool-store .copy \{\
  display: flex; flex-direction: column;\
  line-height: 1; text-align: left; min-width: 0;\
\}\
.ssr-pool-store .copy .small \{\
  font-size: 9px;\
  letter-spacing: 0.15em;\
  text-transform: uppercase;\
  color: #fff;\
  opacity: 0.85;\
  margin-bottom: 3px;\
  font-weight: 500;\
\}\
.ssr-pool-store .copy .big \{\
  font-size: 15px;\
  font-weight: 800;\
  letter-spacing: 0.01em;\
  color: #fff;\
  white-space: nowrap;\
\}\
@keyframes ssr-pool-store-pulse \{\
  0%, 100% \{ box-shadow: 0 0 12px rgba(255,149,0, 0.18); \}\
  50%      \{ box-shadow: 0 0 22px rgba(255,149,0, 0.50); \}\
\}\
.ssr-pool-store \{\
  animation: ssr-pool-store-pulse 3s ease-in-out infinite;\
\}\
\
/* bottom tagline */\
.ssr-pool-tagline \{\
  margin-top: 12px;\
  padding-top: 10px;\
  border-top: 1px dashed rgba(232,112,10, 0.45);\
  font-family: 'JetBrains Mono', Menlo, Monaco, Consolas, monospace;\
  font-size: 10px;\
  letter-spacing: 0.20em;\
  text-transform: uppercase;\
  color: #d8d2c8;\
  text-align: center;\
  line-height: 1.5;\
\}\
.ssr-pool-tagline strong \{ color: #ff9500; font-weight: 800; \}\
.ssr-pool-tagline .eq \{ color: #2bd97a; font-weight: 800; \}\
\
/* ============================================================\
   REDUCED MOTION\
   ============================================================ */\
@media (prefers-reduced-motion: reduce) \{\
  .ssr-pool-radar,\
  .ssr-pool-ripples span,\
  .ssr-pool-rings::after,\
  .ssr-pool-notes .note,\
  .ssr-pool-core,\
  .ssr-pool-sparkles i,\
  .ssr-pool-eq span,\
  .ssr-pool-ticker .show,\
  .ssr-pool-live .dot,\
  .ssr-pool-store \{ animation: none; \}\
  .ssr-pool-ticker .show:nth-child(1) \{ opacity: 1; \}\
\}\
</style>\
