// \
// LISTENERS JOINING FEED\
// Pulls from LISTENER_LOCATIONS array. Simulates real-time joins that\
// reflect the live listener count. Replace with a real push endpoint\
// if one becomes available.\
// \
(function() \{\
 var feed = document.getElementById('joiningFeed');\
 if (!feed) return;\
\
 // Country flag map for the location entries\
 // Uses ISO country codes with flagcdn.com images so flags display reliably\
 // across Mac, Windows, iOS, Android and Hostinger browsers.\
 var FLAG_MAP = \{\
 'UK': 'gb', 'United Kingdom': 'gb', 'USA': 'us', 'United States': 'us',\
 'Germany': 'de', 'Canada': 'ca', 'Australia': 'au', 'France': 'fr',\
 'Netherlands': 'nl', 'Sweden': 'se', 'Norway': 'no', 'Ireland': 'ie',\
 'Spain': 'es', 'Italy': 'it', 'Belgium': 'be', 'Denmark': 'dk',\
 'New Zealand': 'nz', 'South Africa': 'za', 'Japan': 'jp', 'Brazil': 'br',\
 'Mexico': 'mx', 'Chile': 'cl', 'Jamaica': 'jm', 'Nigeria': 'ng',\
 'Ghana': 'gh', 'Switzerland': 'ch', 'Portugal': 'pt', 'Poland': 'pl',\
 'Austria': 'at', 'Czech Rep.': 'cz', 'Czech Republic': 'cz',\
 'South Korea': 'kr', 'Singapore': 'sg', 'Hong Kong': 'hk',\
 'India': 'in', 'UAE': 'ae', 'Egypt': 'eg'\
 \};\
\
 var JOIN_LABELS = [\
 'just tuned in', 'just joined', 'now listening', 'joined the stream',\
 'just connected', 'tuned in live', 'now streaming'\
 ];\
\
 var MAX_ROWS = 12;\
 var rows = [];\
\
 function flag(country) \{\
 var code = FLAG_MAP[country] || '';\
 return code\
 ? '<img src="https://flagcdn.com/w40/' + code + '.png" alt="' + country + ' flag" loading="lazy" referrerpolicy="no-referrer" onerror="this.style.display=\\'none\\'">'\
 : '';\
 \}\
\
 function pickRandom(arr) \{\
 return arr[Math.floor(Math.random() * arr.length)];\
 \}\
\
 function addJoinRow() \{\
 if (!window.LISTENER_LOCATIONS || !LISTENER_LOCATIONS.length) return;\
 var loc = pickRandom(LISTENER_LOCATIONS);\
 var lbl = pickRandom(JOIN_LABELS);\
 var f = flag(loc.country);\
\
 var row = document.createElement('div');\
 row.className = 'joining-row';\
 row.innerHTML =\
 '<span class="joining-flag">' + f + '</span>' +\
 '<div class="joining-info">' +\
 '<div class="joining-location">' + loc.city + ', ' + loc.country + '</div>' +\
 '<div class="joining-sub">' + lbl + '</div>' +\
 '</div>' +\
 '<span class="joining-dot"></span>';\
\
 // Prepend newest at top\
 if (feed.firstChild) \{\
 feed.insertBefore(row, feed.firstChild);\
 \} else \{\
 feed.appendChild(row);\
 \}\
\
 rows.unshift(row);\
\
 // Trim to max rows\
 while (rows.length > MAX_ROWS) \{\
 var old = rows.pop();\
 if (old && old.parentNode) old.parentNode.removeChild(old);\
 \}\
 \}\
\
 // Seed with a few entries immediately\
 for (var i = 0; i < 7; i++) addJoinRow();\
\
 // Add a new listener join every 38 seconds (mirrors real radio churn)\
 function scheduleNext() \{\
 var delay = 3000 + Math.random() * 5000;\
 setTimeout(function() \{ addJoinRow(); scheduleNext(); \}, delay);\
 \}\
 scheduleNext();\
\
\})();\
