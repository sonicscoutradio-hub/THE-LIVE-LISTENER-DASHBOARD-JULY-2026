 var html = SHOWS.map(function(show) \{\
 var isLive = show.id === current.id;\
 var trendVal = (typeof show.trend === 'number') ? show.trend : 0;\
 var trendClass = trendVal >= 0 ? 'trend-up' : 'trend-down';\
 var trendSign = trendVal >= 0 ? '+' : '';\
